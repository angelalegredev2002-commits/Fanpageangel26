---
const recentActivity = [
  { user: 'Carlos M.', action: 'Nueva Consulta', time: 'Hace 5 min' },
  { user: 'Angel Alegre', action: 'Actualizó sección "Precios"', time: 'Hace 1 hora' },
  { user: 'Angel Alegre', action: 'Añadió nueva imagen al Media Library', time: 'Hace 3 horas' },
  { user: 'Laura G.', action: 'Mensaje sobre "Ecosystem Plan"', time: 'Ayer' },
];
---
<div class="bg-white/50 dark:bg-neutral-900/50 backdrop-blur-sm border border-neutral-200 dark:border-neutral-800 rounded-2xl p-6 transition-colors duration-300">
  <h2 class="text-xl font-bold text-neutral-900 dark:text-white mb-6">Actividad Reciente</h2>
  <div class="space-y-6">
    {recentActivity.map((activity, index) => (
      <div class="flex gap-4">
        <div class="relative flex flex-col items-center">
          <div class="w-3 h-3 rounded-full bg-orange-500 mt-1"></div>
          {index !== recentActivity.length - 1 && (
            <div class="w-px h-full bg-neutral-200 dark:bg-neutral-800 absolute top-4"></div>
          )}
        </div>
        <div>
          <p class="text-sm font-medium text-neutral-900 dark:text-white">{activity.user}</p>
          <p class="text-sm text-neutral-500 dark:text-neutral-400">{activity.action}</p>
          <p class="text-xs text-neutral-400 dark:text-neutral-500 mt-1">{activity.time}</p>
        </div>
      </div>
    ))}
  </div>
  <button class="w-full mt-6 py-2 border border-neutral-200 dark:border-neutral-800 hover:border-orange-500/50 dark:hover:border-orange-500/50 text-neutral-600 dark:text-neutral-300 hover:text-orange-500 dark:hover:text-orange-400 rounded-xl transition-colors text-sm font-medium">
    Ver Toda la Actividad
  </button>
</div>
