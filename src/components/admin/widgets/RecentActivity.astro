---
const recentActivity = [
  { user: 'Carlos M.', action: 'Nueva Consulta', time: 'Hace 5 min' },
  {
    user: 'Angel Alegre',
    action: 'Actualizó sección "Precios"',
    time: 'Hace 1 hora',
  },
  {
    user: 'Angel Alegre',
    action: 'Añadió nueva imagen al Media Library',
    time: 'Hace 3 horas',
  },
  { user: 'Laura G.', action: 'Mensaje sobre "Ecosystem Plan"', time: 'Ayer' },
];
---

<div
  class="rounded-2xl border border-neutral-200 bg-white/50 p-6 backdrop-blur-sm transition-colors duration-300 dark:border-neutral-800 dark:bg-neutral-900/50"
>
  <h2 class="mb-6 text-xl font-bold text-neutral-900 dark:text-white">
    Actividad Reciente
  </h2>
  <div class="space-y-6">
    {
      recentActivity.map((activity, index) => (
        <div class="flex gap-4">
          <div class="relative flex flex-col items-center">
            <div class="mt-1 h-3 w-3 rounded-full bg-orange-500" />
            {index !== recentActivity.length - 1 && (
              <div class="absolute top-4 h-full w-px bg-neutral-200 dark:bg-neutral-800" />
            )}
          </div>
          <div>
            <p class="text-sm font-medium text-neutral-900 dark:text-white">
              {activity.user}
            </p>
            <p class="text-sm text-neutral-500 dark:text-neutral-400">
              {activity.action}
            </p>
            <p class="mt-1 text-xs text-neutral-400 dark:text-neutral-500">
              {activity.time}
            </p>
          </div>
        </div>
      ))
    }
  </div>
  <button
    class="mt-6 w-full rounded-xl border border-neutral-200 py-2 text-sm font-medium text-neutral-600 transition-colors hover:border-orange-500/50 hover:text-orange-500 dark:border-neutral-800 dark:text-neutral-300 dark:hover:border-orange-500/50 dark:hover:text-orange-400"
  >
    Ver Toda la Actividad
  </button>
</div>
