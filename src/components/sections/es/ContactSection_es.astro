---
// Import the necessary dependencies.
import AuthBtn from '@components/ui/buttons/AuthBtn.astro';
import ContactIconBlock from '@components/ui/blocks/ContactIconBlock.astro';
import TextInput from '@components/ui/forms/input/TextInput.astro';
import EmailContactInput from '@components/ui/forms/input/EmailContactInput.astro';
import PhoneInput from '@components/ui/forms/input/PhoneInput.astro';
import TextAreaInput from '@components/ui/forms/input/TextAreaInput.astro';
import Icon from '@components/ui/icons/Icon.astro';

// Define the variables that will be used in this component
const title: string = 'Contáctanos';
const subTitle: string =
  '¿Tienes preguntas o quieres discutir un proyecto? Contáctanos y permítenos elaborar la solución perfecta con nuestras herramientas y servicios.';
const formTitle: string = 'Completa el formulario a continuación';
const formSubTitle: string =
  'Te responderemos en un plazo de 1 a 2 días hábiles.';
---

<section class="relative overflow-hidden bg-neutral-200 dark:bg-neutral-950">
  <div class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:max-w-5xl">
      {/* Header Section */}
      <div class="mb-12 text-center">
        <h1
          class="text-3xl font-black tracking-tight text-neutral-800 md:text-5xl dark:text-neutral-200"
        >
          {title}
        </h1>
        <p class="mt-4 text-base text-neutral-600 dark:text-neutral-400">
          {subTitle}
        </p>
      </div>

      <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
        {/* Left Column: Form (No background card) */}
        <div class="space-y-8">
          <div class="space-y-2">
            <h2
              class="text-2xl font-bold text-neutral-800 dark:text-neutral-200"
            >
              {formTitle}
            </h2>
            <p class="text-sm text-neutral-500">
              {formSubTitle}
            </p>
          </div>

          <form
            id="contact-form-es"
            action="https://formspree.io/f/xpwzgpeg"
            method="POST"
            class="grid gap-4"
          >
            <input
              type="hidden"
              name="_subject"
              value="Nuevo contacto desde Fanpage"
            />
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <TextInput
                id="hs-firstname-contacts"
                label="Nombre"
                name="firstname"
              />
              <TextInput
                id="hs-lastname-contacts"
                label="Apellido"
                name="lastname"
              />
            </div>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <EmailContactInput
                id="hs-email-contacts"
                label="Correo electrónico"
              />
              <PhoneInput id="hs-phone-number" label="Número de teléfono" />
            </div>

            <TextAreaInput
              id="hs-about-contacts"
              label="¿Cómo podemos ayudarte?"
              name="message"
            />

            <div class="mt-4">
              <AuthBtn title="Enviar Mensaje Ahora" />
            </div>
          </form>
        </div>

        {/* Right Column: Contact Details */}
        <div class="space-y-8 lg:ps-10">
          <div class="space-y-6">
            <a
              href="https://maps.google.com/maps?q=Jirón+Jacintos+2128,+San+Juan+de+Lurigancho+15434"
              target="_blank"
              class="group flex gap-x-5 rounded-2xl p-4 transition-all hover:bg-white/50 dark:hover:bg-neutral-900/50"
            >
              <Icon
                name="mapPin"
                class="size-6 shrink-0 text-orange-500 transition-transform group-hover:scale-110"
              />
              <div class="grow">
                <h3 class="font-bold text-neutral-800 dark:text-neutral-200">
                  Oficina Central
                </h3>
                <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
                  Jirón Jacintos 2128, San Juan de Lurigancho 15434, Lima, Perú
                </p>
                <span
                  class="mt-2 inline-flex items-center gap-x-2 text-sm font-bold text-orange-600 underline decoration-transparent transition-all group-hover:decoration-current dark:text-orange-500"
                >
                  Ver en Google Maps <Icon name="arrowUpRight" class="size-3" />
                </span>
              </div>
            </a>

            <a
              href="mailto:angelalegredev2002@gmail.com?subject=Consulta%20desde%20Fanpage%20-%20[Okanox%20ERP]&body=Hola%20Angel,%0D%0A%0D%0AMe%20gustaría%20obtener%20más%20información%20sobre..."
              class="group flex gap-x-5 rounded-2xl p-4 transition-all hover:bg-white/50 dark:hover:bg-neutral-900/50"
            >
              <Icon
                name="envelopeOpen"
                class="size-6 shrink-0 text-blue-500 transition-transform group-hover:scale-110"
              />
              <div class="grow">
                <h3 class="font-bold text-neutral-800 dark:text-neutral-200">
                  Email
                </h3>
                <p
                  class="mt-1 text-sm font-bold text-neutral-600 transition-colors group-hover:text-orange-500 dark:text-neutral-400"
                >
                  angelalegredev2002@gmail.com
                </p>
              </div>
            </a>

            <div class="flex gap-x-5">
              <Icon
                name="chatBubble"
                class="size-6 shrink-0 text-emerald-500"
              />
              <div class="grow">
                <h3 class="font-bold text-neutral-800 dark:text-neutral-200">
                  FAQs & Soporte
                </h3>
                <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
                  Respuestas rápidas y guías detalladas.
                </p>
                <div class="mt-2 flex gap-4">
                  <a
                    href="/es/faqs"
                    class="text-sm font-bold text-orange-600 hover:text-orange-700 dark:text-orange-500"
                    >Ir a FAQ</a
                  >
                  <a
                    href="#"
                    class="text-sm font-bold text-blue-600 hover:text-blue-700 dark:text-blue-400"
                    >Documentación</a
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Map Section - Wide and Integrated */}
      <div class="group relative mt-16">
        <div
          class="absolute -inset-1 rounded-3xl bg-gradient-to-r from-orange-500/20 to-blue-500/20 opacity-50 blur-lg transition duration-1000 group-hover:opacity-100"
        >
        </div>
        <div
          class="relative h-[400px] overflow-hidden rounded-3xl border border-neutral-300 shadow-2xl dark:border-neutral-800"
        >
          <iframe
            title="Ubicación exacta Okanox ERP"
            src="https://www.google.com/maps?q=Jirón+Jacintos+2128,San+Juan+de+Lurigancho+15434,Peru&hl=es&z=17&output=embed"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            class="transition-all duration-700"></iframe>
        </div>
      </div>
    </div>
  </div>

  {/* Success Notification Modal */}
  <div
    id="contact-success-modal"
    class="hs-overlay pointer-events-none fixed start-0 top-0 z-[80] hidden size-full overflow-x-hidden overflow-y-auto"
    role="dialog"
    tabindex="-1"
  >
    <div
      class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:scale-100 m-3 mt-0 flex min-h-[calc(100%-3.5rem)] scale-95 items-center text-center opacity-0 transition-all sm:mx-auto sm:w-full sm:max-w-lg"
    >
      <div
        class="pointer-events-auto flex w-full flex-col rounded-3xl border border-neutral-200 bg-white p-8 shadow-2xl dark:border-neutral-800 dark:bg-neutral-900"
      >
        <div
          class="mx-auto mb-6 flex size-20 items-center justify-center rounded-full bg-emerald-500/10 text-emerald-500"
        >
          <Icon name="checkCircle" class="size-10" />
        </div>
        <h3
          class="mb-2 text-2xl font-black text-neutral-800 dark:text-neutral-200"
        >
          ¡Mensaje Enviado!
        </h3>
        <p class="mb-8 text-neutral-600 dark:text-neutral-400">
          Gracias por contactarnos. Tu mensaje ha sido recibido con éxito. Angel
          Alegre se pondrá en contacto contigo muy pronto.
        </p>
        <button
          type="button"
          class="inline-flex items-center justify-center gap-x-2 rounded-xl border border-transparent bg-orange-500 px-6 py-3 text-sm font-black text-white transition-all hover:bg-orange-600 focus:ring-2 focus:ring-orange-500 focus:outline-hidden"
          data-hs-overlay="#contact-success-modal"
        >
          Entendido, gracias
        </button>
      </div>
    </div>
  </div>

  {/* Hidden Trigger for the modal */}
  <button
    id="trigger-success-modal"
    class="hidden"
    data-hs-overlay="#contact-success-modal"></button>
</section>

<script>
  const WHATSAPP_NUMBER = '51954711074';

  function handleFormSubmit() {
    const form = document.getElementById(
      'contact-form-es'
    ) as HTMLFormElement | null;
    const triggerBtn = document.getElementById('trigger-success-modal');

    if (!form) return;

    form.addEventListener('submit', async e => {
      e.preventDefault();

      const data = new FormData(form);
      const firstname = data.get('firstname') || '';
      const lastname = data.get('lastname') || '';
      const email =
        (form.querySelector('#hs-email-contacts') as HTMLInputElement)?.value ||
        '';
      const phone =
        (form.querySelector('#hs-phone-number') as HTMLInputElement)?.value ||
        '';
      const message = data.get('message') || '';

      // 1. Enviar al correo vía Formspree
      try {
        await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
      } catch (_) {
        // continuar de todas formas — WhatsApp lleva el mensaje
      }

      // 2. Abrir WhatsApp con el mensaje pre-completado
      const waText = encodeURIComponent(
        `📩 Nuevo contacto desde Fanpage:\n\n👤 Nombre: ${firstname} ${lastname}\n📧 Email: ${email}\n📞 Teléfono: ${phone}\n\n💬 Mensaje:\n${message}`
      );
      window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${waText}`, '_blank');

      // 3. Mostrar modal de éxito
      if (triggerBtn) triggerBtn.click();
      form.reset();
    });
  }

  document.addEventListener('astro:page-load', handleFormSubmit);
  if (!document.documentElement.hasAttribute('data-astro-transition')) {
    handleFormSubmit();
  }
</script>
