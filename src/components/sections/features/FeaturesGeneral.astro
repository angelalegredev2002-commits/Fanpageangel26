---
// Import the necessary dependencies
import { Image } from 'astro:assets';
import Icon from '@components/ui/icons/Icon.astro';

interface Feature {
  heading: string;
  content: string;
  svg: string;
}

interface Props {
  title?: string;
  subTitle?: string;
  features?: Feature[];
  src?: any;
  alt?: string;
}
// Define props from Astro
const { title, subTitle, src, alt, features } = Astro.props;
---

<section
  class="scroll-order-section mx-auto max-w-[85rem] px-4 py-8 sm:px-6 lg:px-8 lg:py-20 2xl:max-w-full"
  data-pin="true"
>
  <div class="scroll-order-pin relative flex min-h-0 flex-col justify-center overflow-hidden md:min-h-[100dvh]">
    <div
      class="absolute -top-20 -right-20 -z-10 size-64 rounded-full bg-orange-500/10 blur-[100px]"
    >
    </div>

    <div
      class="scroll-order-header mb-10 grid grid-cols-2 items-center gap-6 sm:mb-16 sm:block"
    >
      <div class="flex flex-col gap-y-2 sm:gap-y-6">
        <h2
          class="text-xl leading-tight font-black tracking-tight text-balance text-neutral-800 sm:text-5xl dark:text-neutral-100"
        >
          {title}
        </h2>
        {
          subTitle && (
            <p class="text-[9px] leading-relaxed font-medium text-neutral-600 sm:text-xl dark:text-neutral-400">
              {subTitle}
            </p>
          )
        }
      </div>

      <div
        class="scroll-order-item group/feat-img relative overflow-hidden rounded-3xl border border-neutral-200 shadow-[0_10px_30px_rgba(249,115,22,0.08)] sm:mt-16 dark:border-neutral-800"
        data-scatter-index="0"
        data-scatter-x="-100"
        data-scatter-y="60"
        data-scatter-r="-8"
      >
        {
          src && alt && (
            <Image
              src={src}
              alt={alt}
              class="h-full w-full object-cover object-center transition-transform duration-1000 group-hover/feat-img:scale-110"
              draggable={'false'}
              format={'avif'}
              loading={'eager'}
            />
          )
        }
        <div
          class="absolute inset-0 bg-linear-to-t from-black/20 to-transparent"
        >
        </div>
      </div>
    </div>

    <div
      class="scroll-order-grid mt-8 grid grid-cols-2 gap-3 sm:grid-cols-2 lg:gap-6 xl:grid-cols-4"
    >
      {
        features &&
          features.map((feature, index) => (
            <div
              class="scroll-order-item group flex flex-col gap-y-2 rounded-2xl border border-neutral-200 bg-neutral-50/50 p-3 transition-[box-shadow,border-color] duration-300 hover:shadow-lg dark:border-neutral-800 dark:bg-neutral-900/50"
              data-scatter-index={index + 1}
            >
              <div class="flex items-center gap-x-2">
                <div class="text-orange-500">
                  <Icon name={feature.svg} />
                </div>
                <h3 class="text-[11px] leading-tight font-black tracking-tight text-neutral-800 sm:text-base dark:text-neutral-100">
                  {feature.heading}
                </h3>
              </div>
              <p class="text-[9px] leading-tight text-neutral-600 sm:text-sm dark:text-neutral-400">
                {feature.content}
              </p>
            </div>
          ))
      }
    </div>
  </div>
</section>
