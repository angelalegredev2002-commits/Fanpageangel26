---
// Define props from Astro
const { title, subTitle, partners } = Astro.props;

interface Partner {
  icon: any;
  name?: string;
  href?: string;
}

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  partners: Partner[];
}
---

<section
  class="mx-auto max-w-[85rem] px-4 py-8 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full"
>
  <div
    class="rounded-[2.5rem] border border-neutral-200 bg-neutral-50/50 p-8 backdrop-blur-xl dark:border-neutral-800 dark:bg-white/[.02]"
  >
    {/* Title and description */}
    <div class="mx-auto mb-10 w-full text-center">
      <h2
        class="text-xl font-black tracking-tight text-neutral-800 sm:text-3xl dark:text-neutral-100"
      >
        {title}
      </h2>
      {
        subTitle && (
          <p class="mt-2 text-xs text-neutral-600 sm:text-lg dark:text-neutral-400">
            {subTitle}
          </p>
        )
      }
    </div>

    {/* Clients Marquee - Infinite Loop */}
    <div
      class="relative overflow-hidden [mask-image:linear-gradient(to_right,transparent,white_20%,white_80%,transparent)]"
    >
      <div
        class="animate-marquee flex w-max items-center gap-12 py-4 opacity-50 grayscale transition-all duration-700 hover:opacity-100 hover:grayscale-0 hover:[animation-play-state:paused] lg:gap-24"
      >
        {/* First set of logos */}
        {
          partners.map(partner => (
            <a
              href={partner.href}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 transition-transform duration-300 hover:scale-110"
            >
              <div class="scale-75 sm:scale-100 [&>svg]:h-8 sm:[&>svg]:h-10 [&>svg]:w-auto [&>svg]:max-w-none" set:html={partner.icon} />
            </a>
          ))
        }
        {/* Duplicated set for seamless loop */}
        {
          partners.map(partner => (
            <a
              href={partner.href}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 transition-transform duration-300 hover:scale-110"
            >
              <div class="scale-75 sm:scale-100 [&>svg]:h-8 sm:[&>svg]:h-10 [&>svg]:w-auto [&>svg]:max-w-none" set:html={partner.icon} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
