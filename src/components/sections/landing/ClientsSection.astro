---
// Define props from Astro
const { title, subTitle, partners } = Astro.props;

interface Partner {
  icon: any;
  name?: string;
  href?: string;
}

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  partners: Partner[];
}
---

<section
  class="mx-auto max-w-[85rem] px-4 py-8 sm:px-6 lg:px-8 lg:py-16 2xl:max-w-full"
>
  <div class="rounded-[2.5rem] border border-neutral-200 bg-neutral-50/50 p-8 dark:border-neutral-800 dark:bg-white/[.02] backdrop-blur-xl">
    {/* Title and description */}
    <div class="mx-auto mb-10 w-full text-center">
      <h2
        class="text-xl sm:text-3xl font-black tracking-tight text-neutral-800 dark:text-neutral-100"
      >
        {title}
      </h2>
      {
        subTitle && (
          <p class="mt-2 text-xs sm:text-lg text-neutral-600 dark:text-neutral-400">
            {subTitle}
          </p>
        )
      }
    </div>

    {/* Clients Marquee - Infinite Loop */}
    <div class="relative overflow-hidden [mask-image:linear-gradient(to_right,transparent,white_20%,white_80%,transparent)]">
      <div class="animate-marquee flex gap-12 lg:gap-24 items-center py-4 grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-700">
        {/* First set of logos */}
        {
          partners.map(partner => (
            <a href={partner.href} target="_blank" rel="noopener noreferrer" class="shrink-0 transition-transform duration-300 hover:scale-110">
              <div class="scale-75 sm:scale-100" set:html={partner.icon} />
            </a>
          ))
        }
        {/* Duplicated set for seamless loop */}
        {
          partners.map(partner => (
            <a href={partner.href} target="_blank" rel="noopener noreferrer" class="shrink-0 transition-transform duration-300 hover:scale-110">
              <div class="scale-75 sm:scale-100" set:html={partner.icon} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
