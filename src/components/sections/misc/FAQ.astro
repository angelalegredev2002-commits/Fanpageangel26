---
const { title, faqs } = Astro.props;

// Define TypeScript interface for props
interface Faq {
  question: string;
  answer: string;
}

interface FaqGroup {
  subTitle?: string;
  faqs: Faq[];
}

interface Props {
  title: string;
  faqs: FaqGroup;
}
// Define a helper function to generate ids dynamically.
const makeId = (base: any, index: any) => `${base}${index + 1}`;
---

<section
  class="mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-20 2xl:max-w-full"
>
  <div class="grid gap-10 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:items-start">
    <div class="lg:sticky lg:top-24">
      <span class="inline-flex items-center rounded-full border border-orange-500/20 bg-orange-500/8 px-4 py-2 text-[0.7rem] font-black tracking-[0.24em] text-orange-600 uppercase dark:border-orange-400/20 dark:bg-orange-400/10 dark:text-orange-300">
        FAQ
      </span>
      <h2
        class="mt-5 text-3xl font-black tracking-tight text-neutral-900 sm:text-4xl dark:text-neutral-100"
      >
        <Fragment set:html={title} />
      </h2>
      <p class="mt-4 max-w-xl text-base leading-7 text-neutral-600 dark:text-neutral-400">
        {faqs.subTitle}
      </p>
    </div>

    <div
      class="hs-accordion-group stagger-children border-t border-neutral-200 dark:border-neutral-800"
    >
      {
        faqs.faqs.map((question, i) => {
          let id = makeId('hs-faq-grid-heading-', i);
          let collapseId = makeId('hs-faq-grid-collapse-', i);
          return (
            <div
              class="hs-accordion border-b border-neutral-200 py-5 transition-colors duration-300 dark:border-neutral-800"
              id={id}
            >
              <button
                class="hs-accordion-toggle inline-flex w-full items-start justify-between gap-x-5 text-start transition hover:text-orange-500 dark:hover:text-orange-400"
                aria-expanded="false"
                aria-controls={collapseId}
              >
                <span class="pr-4 text-base leading-snug font-bold text-neutral-900 sm:text-lg dark:text-neutral-100">
                  {question.question}
                </span>
                <span class="mt-1 inline-flex size-8 shrink-0 items-center justify-center rounded-full border border-neutral-200 text-neutral-500 transition-all duration-300 hs-accordion-active:rotate-180 hs-accordion-active:border-orange-500/40 hs-accordion-active:text-orange-500 dark:border-neutral-700 dark:text-neutral-400 dark:hs-accordion-active:border-orange-400/40 dark:hs-accordion-active:text-orange-300">
                  <svg
                    class="size-4"
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                </span>
              </button>
              <div
                id={collapseId}
                class="hs-accordion-content hidden w-full overflow-hidden transition-[height] duration-300"
                role="region"
                aria-labelledby={id}
              >
                <div class="max-w-2xl pt-4">
                  <p class="text-sm leading-7 text-neutral-600 sm:text-base dark:text-neutral-400">
                    {question.answer}
                  </p>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
