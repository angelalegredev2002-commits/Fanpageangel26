---
// Import SecondaryCTA component for use in this module
import SecondaryCTA from '@components/ui/buttons/SecondaryCTA.astro';
import Icon from '@components/ui/icons/Icon.astro';

// Define props from Astro
const { pricing } = Astro.props;

// Define TypeScript type for products.
type Product = {
  name: string;
  description: string;
  price: string;
  cents: string;
  billingFrequency: string;
  features: Array<string>;
  purchaseBtnTitle: string;
  purchaseLink: string;
  modules?: Array<string>;
};

interface PricingSectionProps {
  title: string;
  subTitle: string;
  badge: string;
  thirdOption: string;
  btnText: string;
  pricing: {
    title: string;
    subTitle: string;
    badge: string;
    thirdOption: string;
    btnText: string;
    plans: Array<Product & { highlight: boolean }>;
  };
}
---

<section
  class="relative mx-auto max-w-[85rem] px-4 py-12 sm:px-6 lg:px-8 lg:py-24 2xl:max-w-full"
>
  <!-- Decorative background aura -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 -z-10 size-full max-w-4xl bg-orange-500/5 blur-[120px] rounded-full overflow-hidden"></div>

  {/* Section heading and sub-heading */}
  <div class="mx-auto mb-12 max-w-3xl text-center lg:mb-20">
    <h2
      class="text-4xl font-black tracking-tight text-balance text-neutral-800 md:text-5xl lg:text-6xl md:leading-tight dark:text-neutral-100"
    >
      {pricing.title}
    </h2>
    <div class="mt-6 flex justify-center">
        <div class="h-1.5 w-24 rounded-full bg-orange-500/20 backdrop-blur-md border border-orange-500/30 dark:bg-white/10 dark:border-white/20"></div>
    </div>
    <p class="mt-8 text-lg font-medium leading-relaxed text-neutral-600 sm:text-xl dark:text-neutral-400">
      {pricing.subTitle}
    </p>
  </div>
  {/* Plans Grid / Carousel on Mobile */}
  <div class="stagger-children flex items-stretch gap-4 overflow-x-auto pt-8 pb-16 snap-x snap-mandatory scrollbar-hide sm:grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 md:gap-6 sm:overflow-visible sm:pt-0 sm:pb-0">
    {
      pricing.plans.map((plan: Product & { highlight: boolean }, index: number) => (
        <div
          class={`tilt-element group relative flex w-[85vw] shrink-0 snap-center flex-col rounded-3xl p-6 transition-all duration-700 sm:w-auto hover:z-20 ${
            plan.highlight
              ? "bg-orange-500/10 backdrop-blur-2xl ring-2 ring-orange-500/50 shadow-[0_20px_50px_rgba(249,115,22,0.15)]"
              : "bg-white/10 dark:bg-neutral-900/30 backdrop-blur-xl border border-white/20 dark:border-neutral-800/50 shadow-sm hover:shadow-2xl"
          } hover:-rotate-y-6 hover:scale-[1.02] perspective-1000 transform-style-3d`}
          style="perspective: 1000px;"
        >
          {plan.highlight && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-linear-to-r from-orange-500 to-orange-600 text-white text-[8px] sm:text-[10px] font-bold uppercase tracking-widest py-1 px-3 sm:py-1.5 sm:px-4 rounded-full shadow-lg z-30">
              Recomendado
            </div>
          )}

          <div class="mb-4 sm:mb-6 relative z-10">
            <div class="flex items-start justify-between">
              <div>
                <h3 class={`text-sm sm:text-lg font-extrabold tracking-tight ${plan.highlight ? "text-orange-600 dark:text-orange-400" : "text-neutral-900 dark:text-neutral-100"}`}>
                  {plan.name}
                </h3>
                <p class={`text-[10px] sm:text-xs mt-0.5 font-medium ${plan.highlight ? "text-orange-700/80 dark:text-orange-200/80" : "text-neutral-500 dark:text-neutral-400"}`}>
                  {plan.description}
                </p>
              </div>
              <button
                type="button"
                class={`p-1.5 sm:p-2 shrink-0 rounded-xl transition-all duration-300 ${
                  plan.highlight 
                    ? "bg-orange-500/20 hover:bg-orange-500/40 text-orange-600 dark:text-orange-400" 
                    : "bg-orange-50/50 dark:bg-orange-950/30 hover:bg-orange-100 text-orange-600 dark:text-orange-400"
                }`}
                data-hs-overlay={`#hs-pricing-modal-${index}`}
                title="Ver desglose de módulos"
              >
                <Icon name="info" class="size-3.5 sm:size-4" />
              </button>
            </div>
          </div>

          <div class="mb-6 sm:mb-8 relative z-10">
            <div class="flex items-baseline gap-1">
              <span class={`text-2xl sm:text-4xl font-black ${plan.highlight ? "text-neutral-900 dark:text-white" : "text-neutral-900 dark:text-neutral-100"}`}>
                {plan.price}
              </span>
              <span class={`text-xs sm:text-sm font-bold ${plan.highlight ? "text-orange-600 dark:text-orange-200" : "text-neutral-500 dark:text-neutral-400"}`}>
                {plan.cents}
              </span>
            </div>
            <p class={`text-[8px] sm:text-[10px] mt-0.5 font-bold uppercase tracking-wider ${plan.highlight ? "text-orange-600 dark:text-orange-300" : "text-neutral-400"}`}>
              {plan.billingFrequency}
            </p>
          </div>

          <ul class="mb-6 sm:mb-8 space-y-2 sm:space-y-4 grow relative z-10">
            {plan.features.map((feature: string) => (
              <li class="flex items-start gap-2 text-[11px] sm:text-sm">
                <div class={`mt-0.5 flex size-4 sm:size-5 shrink-0 items-center justify-center rounded-full ${plan.highlight ? "bg-orange-500/20 text-orange-600 dark:text-orange-400" : "bg-emerald-500/10 text-emerald-500"}`}>
                  <Icon name="checkCircle" class="size-3 sm:size-3.5" />
                </div>
                <span class={`leading-tight ${plan.highlight ? "text-neutral-700 dark:text-neutral-200" : "text-neutral-600 dark:text-neutral-300"}`}>
                  {feature}
                </span>
              </li>
            ))}
          </ul>

          <a
            href={plan.purchaseLink}
            class={`relative inline-flex items-center justify-center rounded-xl sm:rounded-2xl px-4 py-3 sm:px-6 sm:py-4 text-xs sm:text-sm font-bold transition-all duration-300 overflow-hidden group/btn z-10 ${
              plan.highlight
                ? "bg-orange-500 text-white hover:bg-orange-600 shadow-[0_10px_20px_rgba(249,115,22,0.3)] hover:shadow-orange-500/40"
                : "bg-neutral-100 dark:bg-neutral-800 text-neutral-900 dark:text-white hover:bg-orange-500 hover:text-white dark:hover:bg-orange-500"
            }`}
          >
            <span class="relative z-10">{plan.purchaseBtnTitle}</span>
          </a>

          {/* Leaf folding effect decoration */}
          <div class="absolute top-0 right-0 size-16 bg-linear-to-bl from-white/10 to-transparent rounded-tr-3xl transition-all duration-500 group-hover:size-24 group-hover:from-white/20"></div>
        </div>
      ))
    }
  </div>
  {/* Modals outside the loop to prevent flickering with scale animations */}
  {
    pricing.plans.map((plan: Product & { highlight: boolean }, index: number) => (
      <div id={`hs-pricing-modal-backdrop-${index}`} class="hidden fixed inset-0 z-[79] bg-neutral-900/50 backdrop-blur-sm transition-all duration-300"></div>
      <div id={`hs-pricing-modal-${index}`} class="hs-overlay hidden size-full fixed top-0 start-0 z-[80] overflow-x-hidden overflow-y-auto pointer-events-none" role="dialog" tabindex="-1" aria-labelledby={`hs-pricing-modal-label-${index}`}>
        <div class="hs-overlay-open:mt-7 mt-0 transition-all sm:max-w-3xl md:max-w-4xl sm:w-full m-3 sm:mx-auto min-h-full flex items-center">
          <div class="flex flex-col bg-white border border-neutral-200 shadow-2xl rounded-3xl pointer-events-auto dark:bg-neutral-950 dark:border-neutral-800 w-full overflow-hidden max-h-[70vh]">
            <!-- Modal Header -->
            <div class="flex justify-between items-center py-3 px-4 border-b bg-neutral-50 dark:bg-neutral-900 dark:border-neutral-800">
              <div class="flex items-center gap-2">
                <div class="size-7 rounded-lg bg-orange-500/10 flex items-center justify-center text-orange-500">
                    <Icon name="info" class="size-4" />
                </div>
                <div>
                    <h3 class="font-black text-sm text-neutral-900 dark:text-neutral-50">
                        Módulos de {plan.name}
                    </h3>
                    <p class="text-[10px] text-neutral-500 dark:text-neutral-400">Desglose del ecosistema ERP</p>
                </div>
              </div>
              <button type="button" class="inline-flex justify-center items-center size-7 rounded-lg bg-neutral-100 text-neutral-600 hover:bg-neutral-200 focus:outline-none dark:bg-neutral-800 dark:text-neutral-300 dark:hover:bg-neutral-700 transition-all" data-hs-overlay={`#hs-pricing-modal-${index}`}>
                <span class="sr-only">Cerrar</span>
                <svg class="shrink-0 size-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
              </button>
            </div>
            
            <!-- Modal Body -->
            <div class="flex-1 p-4 overflow-y-auto overscroll-contain bg-white dark:bg-neutral-950 [&::-webkit-scrollbar]:w-1.5 [&::-webkit-scrollbar-track]:bg-neutral-100 [&::-webkit-scrollbar-thumb]:bg-neutral-300 [&::-webkit-scrollbar-thumb]:rounded-full dark:[&::-webkit-scrollbar-track]:bg-neutral-900 dark:[&::-webkit-scrollbar-thumb]:bg-neutral-700">
              <div class="mb-3 p-3 rounded-xl bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800">
                <p class="text-xs text-neutral-800 dark:text-neutral-200 leading-relaxed font-bold">
                  Este plan activa <span class="text-base font-black text-orange-600 dark:text-orange-500">{plan.modules?.length || 0} módulos</span> especializados para tu gestión empresarial.
                </p>
              </div>

              <div class="grid grid-cols-3 gap-1.5">
                {plan.modules?.map((module: string) => (
                  <div class="flex items-center gap-2 p-2 rounded-xl bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 transition-all hover:bg-neutral-100 dark:hover:bg-neutral-800 group">
                    <div class="shrink-0 size-5 rounded-md bg-emerald-500/10 flex items-center justify-center text-emerald-600 dark:text-emerald-400 group-hover:bg-emerald-500 group-hover:text-white transition-all">
                      <svg class="size-3" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                    </div>
                    <span class="text-xs font-bold text-neutral-900 dark:text-neutral-100">{module}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Modal Footer -->
            <div class="flex justify-end items-center gap-x-2 py-3 px-4 border-t bg-neutral-50 dark:bg-neutral-900 dark:border-neutral-800">
              <button type="button" class="py-1.5 px-4 inline-flex items-center gap-x-2 text-xs font-bold rounded-xl border border-neutral-300 bg-white text-neutral-900 shadow-sm hover:bg-neutral-100 focus:outline-none dark:bg-neutral-800 dark:border-neutral-700 dark:text-neutral-50 dark:hover:bg-neutral-700 transition-all" data-hs-overlay={`#hs-pricing-modal-${index}`}>
                Entendido
              </button>
            </div>
          </div>
        </div>
      </div>
    ))
  }

  {/* Call to action for Enterprise Solutions */}
  <div class="mt-8 flex flex-col items-center justify-center gap-4 md:mt-12 md:flex-row">
    <p class="text-sm text-neutral-600 dark:text-neutral-400 text-center">
      {pricing.thirdOption}
    </p>

    <SecondaryCTA title={pricing.btnText} url="/es/contact" />
  </div>
</section>

<script>
  function initPricingBackdrops() {
    const modals = document.querySelectorAll<HTMLElement>('[id^="hs-pricing-modal-"]:not([id*="backdrop"])');

    modals.forEach((modal) => {
      const backdrop = document.getElementById(modal.id + '-backdrop');
      if (!backdrop) return;

      // Watch for Preline removing/adding the 'hidden' class on the modal
      const observer = new MutationObserver(() => {
        if (modal.classList.contains('hidden')) {
          backdrop.classList.add('hidden');
        } else {
          backdrop.classList.remove('hidden');
        }
      });

      observer.observe(modal, { attributes: true, attributeFilter: ['class'] });

      // Close modal when clicking backdrop
      backdrop.addEventListener('click', () => {
        const HSOverlay = (window as any).HSOverlay;
        if (HSOverlay) {
          HSOverlay.close(modal);
        } else {
          modal.classList.add('hidden');
        }
      });
    });
  }

  // Works with both standard load and Astro View Transitions
  document.addEventListener('astro:page-load', initPricingBackdrops);
  document.addEventListener('DOMContentLoaded', initPricingBackdrops);
</script>
