---
import { getDB } from '../../utils/db';
const lang = Astro.currentLocale || 'es';
const db = getDB();

const content = {
  es: {
    title: db.legal?.cookiesTitle_es || 'Valoramos tu privacidad',
    text: db.legal?.cookiesText_es || 'Utilizamos cookies para mejorar tu experiencia de navegación, mostrar contenido personalizado y analizar nuestro tráfico. Al hacer clic en "Aceptar", aceptas nuestro uso de cookies.',
    link: 'Política de Privacidad',
    url: '/privacy',
    decline: db.legal?.cookiesDecline_es || 'Rechazar',
    accept: db.legal?.cookiesAccept_es || 'Aceptar Cookies'
  },
  en: {
    title: db.legal?.cookiesTitle_en || 'We value your privacy',
    text: db.legal?.cookiesText_en || 'We use cookies to enhance your browsing experience, serve personalized content, and analyze our traffic. By clicking "Accept", you consent to our use of cookies.',
    link: 'Privacy Policy',
    url: '/en/privacy',
    decline: db.legal?.cookiesDecline_en || 'Decline',
    accept: db.legal?.cookiesAccept_en || 'Accept Cookies'
  }
}[lang as 'es' | 'en'];

if (db.legal?.cookiesEnabled !== 'on') {
  return; // Don't render banner if disabled
}
---
<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[100] p-4 md:p-6 translate-y-[150%] transition-transform duration-700 ease-out">
  <div class="max-w-4xl mx-auto bg-white/95 dark:bg-neutral-900/95 backdrop-blur-md border border-neutral-200 dark:border-neutral-800 p-6 rounded-2xl shadow-2xl shadow-orange-500/10 flex flex-col md:flex-row items-center gap-6 justify-between">
    <div class="flex-1">
      <h3 class="text-lg font-bold text-neutral-900 dark:text-white mb-2">{content.title}</h3>
      <p class="text-neutral-600 dark:text-neutral-400 text-sm leading-relaxed">
        {content.text} <a href={content.url} class="text-orange-500 hover:text-orange-600 dark:hover:text-orange-400 underline transition-colors">{content.link}</a>.
      </p>
    </div>
    <div class="flex items-center gap-4 shrink-0 w-full md:w-auto">
      <button id="cookie-decline" class="flex-1 md:flex-none px-6 py-2.5 rounded-xl border border-neutral-300 dark:border-neutral-700 hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-700 dark:text-neutral-300 font-medium transition-colors">
        {content.decline}
      </button>
      <button id="cookie-accept" class="flex-1 md:flex-none px-6 py-2.5 rounded-xl bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-medium transition-all shadow-lg shadow-orange-500/20">
        {content.accept}
      </button>
    </div>
  </div>
</div>

<script>
  const initCookieBanner = () => {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');
    const declineBtn = document.getElementById('cookie-decline');

    // Comprobar si ya se ha aceptado o rechazado
    const cookieConsent = localStorage.getItem('cookie_consent');

    if (!cookieConsent && banner) {
      // Mostrar el banner con una animación suave después de 1.5 segundos
      setTimeout(() => {
        banner.classList.remove('translate-y-[150%]');
      }, 1500);
    }

    const hideBanner = (status: string) => {
      localStorage.setItem('cookie_consent', status);
      if (banner) {
        banner.classList.add('translate-y-[150%]');
      }
    };

    if (acceptBtn) acceptBtn.addEventListener('click', () => hideBanner('accepted'));
    if (declineBtn) declineBtn.addEventListener('click', () => hideBanner('declined'));
  };

  // Run immediately
  initCookieBanner();
  document.addEventListener('astro:page-load', initCookieBanner);
</script>
