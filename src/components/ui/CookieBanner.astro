---
import { getDB } from '../../utils/db';
const lang = Astro.currentLocale || 'es';
const db = getDB();

const content = {
  es: {
    title: db.legal?.cookiesTitle_es || 'Valoramos tu privacidad',
    text:
      db.legal?.cookiesText_es ||
      'Utilizamos cookies para mejorar tu experiencia de navegación, mostrar contenido personalizado y analizar nuestro tráfico. Al hacer clic en "Aceptar", aceptas nuestro uso de cookies.',
    link: 'Política de Privacidad',
    url: '/privacy',
    decline: db.legal?.cookiesDecline_es || 'Rechazar',
    accept: db.legal?.cookiesAccept_es || 'Aceptar Cookies',
  },
  en: {
    title: db.legal?.cookiesTitle_en || 'We value your privacy',
    text:
      db.legal?.cookiesText_en ||
      'We use cookies to enhance your browsing experience, serve personalized content, and analyze our traffic. By clicking "Accept", you consent to our use of cookies.',
    link: 'Privacy Policy',
    url: '/en/privacy',
    decline: db.legal?.cookiesDecline_en || 'Decline',
    accept: db.legal?.cookiesAccept_en || 'Accept Cookies',
  },
}[lang as 'es' | 'en'];

if (db.legal?.cookiesEnabled !== 'on') {
  return; // Don't render banner if disabled
}
---

<div
  id="cookie-banner"
  class="fixed right-0 bottom-0 left-0 z-[100] translate-y-[150%] p-4 transition-transform duration-700 ease-out md:p-6"
>
  <div
    class="mx-auto flex max-w-4xl flex-col items-center justify-between gap-6 rounded-2xl border border-neutral-200 bg-white/95 p-6 shadow-2xl shadow-orange-500/10 backdrop-blur-md md:flex-row dark:border-neutral-800 dark:bg-neutral-900/95"
  >
    <div class="flex-1">
      <h3 class="mb-2 text-lg font-bold text-neutral-900 dark:text-white">
        {content.title}
      </h3>
      <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
        {content.text}
        <a
          href={content.url}
          class="text-orange-500 underline transition-colors hover:text-orange-600 dark:hover:text-orange-400"
          >{content.link}</a
        >.
      </p>
    </div>
    <div class="flex w-full shrink-0 items-center gap-4 md:w-auto">
      <button
        id="cookie-decline"
        class="flex-1 rounded-xl border border-neutral-300 px-6 py-2.5 font-medium text-neutral-700 transition-colors hover:bg-neutral-100 md:flex-none dark:border-neutral-700 dark:text-neutral-300 dark:hover:bg-neutral-800"
      >
        {content.decline}
      </button>
      <button
        id="cookie-accept"
        class="flex-1 rounded-xl bg-gradient-to-r from-orange-500 to-orange-600 px-6 py-2.5 font-medium text-white shadow-lg shadow-orange-500/20 transition-all hover:from-orange-400 hover:to-orange-500 md:flex-none"
      >
        {content.accept}
      </button>
    </div>
  </div>
</div>

<script>
  const initCookieBanner = () => {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('cookie-accept');
    const declineBtn = document.getElementById('cookie-decline');

    // Comprobar si ya se ha aceptado o rechazado
    const cookieConsent = localStorage.getItem('cookie_consent');

    if (!cookieConsent && banner) {
      // Mostrar el banner con una animación suave después de 1.5 segundos
      setTimeout(() => {
        banner.classList.remove('translate-y-[150%]');
      }, 1500);
    }

    const hideBanner = (status: string) => {
      localStorage.setItem('cookie_consent', status);
      if (banner) {
        banner.classList.add('translate-y-[150%]');
      }
    };

    if (acceptBtn)
      acceptBtn.addEventListener('click', () => hideBanner('accepted'));
    if (declineBtn)
      declineBtn.addEventListener('click', () => hideBanner('declined'));
  };

  // Run immediately
  initCookieBanner();
  document.addEventListener('astro:page-load', initCookieBanner);
</script>
