---
import BrandLogo from '@components/BrandLogo.astro';
---

<div
  id="loading-overlay"
  class="fixed inset-0 z-[100] flex flex-col items-center justify-center overflow-hidden bg-neutral-950 transition-all duration-1000 ease-in-out"
>
  <div
    class="relative z-10 flex transform flex-col items-center transition-transform duration-1000"
    id="loading-content"
  >
    <div class="mb-8 animate-pulse">
      <BrandLogo class="h-16 w-auto" />
    </div>

    <div class="flex items-center gap-2">
      <div
        class="h-2.5 w-2.5 animate-bounce rounded-full bg-orange-500"
        style="animation-delay: 0s;"
      >
      </div>
      <div
        class="h-2.5 w-2.5 animate-bounce rounded-full bg-orange-500"
        style="animation-delay: 0.2s;"
      >
      </div>
      <div
        class="h-2.5 w-2.5 animate-bounce rounded-full bg-orange-500"
        style="animation-delay: 0.4s;"
      >
      </div>
    </div>
  </div>
</div>

<script is:inline>
  // Hide immediately if already played during this navigation session
  if (window.hasPlayedLoading) {
    const overlay = document.getElementById('loading-overlay');
    if (overlay) overlay.style.display = 'none';
  }
</script>

<script>
  const initLoading = () => {
    const win = window as any;
    const overlay = document.getElementById('loading-overlay');
    const content = document.getElementById('loading-content');

    if (overlay && !win.hasPlayedLoading) {
      // Cinematic CSS timing
      setTimeout(() => {
        // Fade out content first
        if (content) {
          content.style.opacity = '0';
          content.style.transform = 'translateY(-20px)';
        }

        // Then slide up the overlay
        setTimeout(() => {
          overlay.style.transform = 'translateY(-100%)';
          overlay.style.opacity = '0';

          setTimeout(() => {
            overlay.style.display = 'none';
            win.hasPlayedLoading = true;
          }, 1000); // Wait for CSS transition to finish
        }, 400);
      }, 1500); // How long the loading screen shows
    } else if (overlay) {
      overlay.style.display = 'none';
    }
  };

  // Run immediately for initial load
  initLoading();
  // Run on subsequent client-side navigations
  document.addEventListener('astro:page-load', initLoading);
</script>
