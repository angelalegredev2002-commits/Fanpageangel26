---
import { Image } from 'astro:assets';

const { src, alt } = Astro.props;

interface Props {
  src: string;
  alt: string;
}
---

{
  typeof src === 'string' ? (
    <img
      src={src}
      alt={alt}
      class="inline-block h-8 w-8 rounded-full"
      loading="eager"
    />
  ) : (
    <Image
      class="inline-block h-8 w-8 rounded-full"
      src={src}
      alt={alt}
      inferSize
      loading={'eager'}
    />
  )
}
