---
import { Image } from 'astro:assets';
import bannerImage from '@images/starlight/bannergerentedev.png';

const { title, btnId, btnTitle, url } = Astro.props;

interface Props {
  title?: string;
  btnId: string;
  btnTitle: string;
  url: string;
}
---

<astro-banner btnId={btnId}>
  <div
    class="fixed inset-x-0 bottom-8 z-50 flex justify-center px-4 animate-banner-in"
    role="region"
    aria-label="Promotion"
  >
    <div
      class="group relative flex items-center overflow-hidden rounded-[2rem] border border-white/10 bg-neutral-950 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.7)] backdrop-blur-3xl transition-all duration-500 hover:border-orange-500/50 sm:max-w-xl"
    >
      <!-- Premium Background Pattern -->
      <div class="absolute inset-0 z-0 opacity-10"
           style="background-image: radial-gradient(circle, #f97316 0.5px, transparent 0.5px); background-size: 12px 12px;"></div>

      <!-- Left Side: Promo Image (Compact) -->
      <div class="relative z-10 w-32 sm:w-48 shrink-0 h-48 sm:h-56 overflow-hidden">
        <Image 
            src={bannerImage} 
            alt="Gerente Dev" 
            class="h-full w-full object-cover object-top transition-transform duration-1000 group-hover:scale-110"
        />
        <!-- Balanced subtle shading -->
        <div class="absolute inset-y-0 right-0 w-16 bg-linear-to-r from-transparent to-neutral-950"></div>
      </div>

      <!-- Right Side: Content -->
      <div class="relative z-10 flex-1 py-4 pr-10 pl-2">
        <div class="mb-1 flex items-center gap-x-2">
            <span class="inline-flex items-center rounded-full bg-orange-600 px-2 py-0.5 text-[9px] font-black uppercase tracking-wider text-white">
                PROMO
            </span>
            {title && <span class="text-[10px] font-bold text-neutral-500">{title}</span>}
        </div>
        
        <div class="flex flex-col gap-y-1">
            <h4 class="text-sm sm:text-base font-black text-white leading-tight">
                Lidera con <span class="text-orange-500">Okanox</span>
            </h4>
            <p class="text-[10px] text-neutral-400 hidden sm:block leading-tight line-clamp-2">
                Gestión empresarial con precisión y potencia tecnológica.
            </p>
            <a
              class="group/link mt-1 inline-flex items-center gap-x-1.5 text-xs font-bold text-orange-400 transition-colors hover:text-orange-300"
              href={url}
              target="_blank"
            >
              {btnTitle}
              <div class="flex size-6 items-center justify-center rounded-full bg-orange-600 shadow-lg group-hover/link:animate-takeoff transition-all duration-500">
                <svg class="size-3 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19 7-7-7-7"></path><path d="M19 12H5"></path></svg>
              </div>
            </a>
        </div>
      </div>

      <!-- Close Button -->
      <button
        type="button"
        class="absolute top-4 right-4 z-20 flex size-7 items-center justify-center rounded-full text-neutral-500 transition-all duration-300 hover:bg-white/10 hover:text-white"
        id={btnId}
      >
        <span class="sr-only">Close</span>
        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
      
      <!-- Animated Bottom Line -->
      <div class="absolute bottom-0 left-0 h-[2px] w-0 bg-orange-500 transition-all duration-1000 group-hover:w-full"></div>
    </div>
  </div>
</astro-banner>

<style>
  @keyframes banner-in {
    0% { transform: translateY(100px) scale(0.9); opacity: 0; }
    100% { transform: translateY(0) scale(1); opacity: 1; }
  }

  @keyframes takeoff {
    0% { transform: scale(1) rotate(0); }
    20% { transform: scale(0.9) rotate(-15deg) translateX(-2px); }
    100% { transform: scale(1.3) rotate(-12deg) translateX(8px) translateY(-6px); opacity: 0.8; }
  }

  .animate-banner-in {
    animation: banner-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
<script>
  class AstroBanner extends HTMLElement {
    connectedCallback() {
      const btnId = this.getAttribute('btnId');
      const button = this.querySelector(`#${btnId}`);
      if (button != null) {
        button.addEventListener('click', () => this.remove());
      }
    }
  }

  customElements.define('astro-banner', AstroBanner);
</script>
