---
// Import PrimaryCTA component
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';

// Destructure the props passed to the Astro component
const { title, subTitle, btnExists, btnTitle, btnURL } = Astro.props;
// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
}
---

{/* Root section of the component */}
<section
  class="relative mx-auto mt-10 max-w-[85rem] overflow-hidden px-4 py-8 sm:px-6 sm:py-12 lg:px-8 lg:py-14 2xl:max-w-full"
>
  {/* Decorative Background Aura */}
  <div
    class="absolute top-0 left-0 -z-10 size-full max-w-4xl rounded-full bg-orange-500/5 blur-[120px]"
  >
  </div>

  <div class="max-w-(--breakpoint-md)">
    {/* Section title with gradient text effect and reveal animation */}
    <h1
      class="reveal-text mb-6 text-4xl font-black tracking-tight text-balance text-neutral-800 md:text-5xl lg:text-6xl dark:text-neutral-100"
    >
      {title}
    </h1>
    {/* Section subtitle with staggered animation */}
    <p
      class="mb-8 max-w-prose leading-relaxed font-medium text-pretty text-neutral-600 sm:text-xl dark:text-neutral-400"
    >
      {subTitle}
    </p>
    {
      btnExists ? (
        <div class="magnetic-effect flex flex-col space-y-4 sm:flex-row sm:space-y-0 sm:space-x-4">
          <PrimaryCTA title={btnTitle} url={btnURL} />
        </div>
      ) : null
    }
  </div>
</section>
