---
const {
  label = 'Email',
  title = Astro.currentLocale === 'es' ? 'Suscribirse' : 'Subscribe',
  id = 'footer-email-input',
} = Astro.props;

interface Props {
  label?: string;
  title?: string;
  id?: string;
}

const placeholder =
  Astro.currentLocale === 'es' ? 'Ingresa tu correo' : 'Enter your email';

const successMsg =
  Astro.currentLocale === 'es'
    ? '¡Suscrito! Gracias 🎉'
    : 'Subscribed! Thank you 🎉';

const errorMsg =
  Astro.currentLocale === 'es'
    ? 'Error al suscribirse. Inténtalo de nuevo.'
    : 'Error subscribing. Please try again.';
---

<!-- 
  Formspree endpoint: replace xyzabc with your own Formspree form ID.
  Create a free account at https://formspree.io, create a form,
  and paste your endpoint here (e.g. https://formspree.io/f/xyzabc).
  The form will forward submissions to angelalegredev2002@gmail.com.
-->
<form
  id="subscribe-form"
  action="https://formspree.io/f/xpwzgpeg"
  method="POST"
  class="mt-4 flex flex-row flex-nowrap items-center gap-2 rounded-2xl bg-neutral-100 p-1.5 dark:bg-neutral-800 border border-neutral-300 dark:border-neutral-700 focus-within:border-orange-500/50 transition-all shadow-sm"
>
  <div class="flex-1">
    <label for={id} class="sr-only">{label}</label>
    <input
      type="email"
      id={id}
      name="email"
      required
      class="block w-full rounded-xl border-transparent bg-transparent px-3 py-2 text-sm text-neutral-800 caret-orange-500 focus:border-transparent focus:ring-0 disabled:pointer-events-none disabled:opacity-50 dark:text-neutral-200 dark:placeholder:text-neutral-400"
      placeholder={placeholder}
    />
    <!-- Hidden fields for Formspree -->
    <input type="hidden" name="_source" value="footer-subscribe" />
    <input type="hidden" name="_subject" value="Nueva suscripción desde Fanpage" />
  </div>
  <button
    type="submit"
    id="subscribe-btn"
    class="inline-flex shrink-0 items-center justify-center gap-x-2 rounded-xl bg-orange-500 px-4 py-2 text-xs font-bold whitespace-nowrap text-white transition duration-300 hover:bg-orange-600 focus:outline-none disabled:pointer-events-none disabled:opacity-50 shadow-md shadow-orange-500/20"
  >
    {title}
  </button>
</form>

<p id="subscribe-success" class="hidden mt-2 text-sm font-semibold text-emerald-600 dark:text-emerald-400">
  {successMsg}
</p>
<p id="subscribe-error" class="hidden mt-2 text-sm font-semibold text-red-500">
  {errorMsg}
</p>

<script>
  function initSubscribeForm() {
    const form = document.getElementById('subscribe-form') as HTMLFormElement | null;
    const btn = document.getElementById('subscribe-btn') as HTMLButtonElement | null;
    const success = document.getElementById('subscribe-success');
    const error = document.getElementById('subscribe-error');

    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btn) return;

      btn.disabled = true;
      btn.textContent = '...';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
          error?.classList.add('hidden');
        } else {
          throw new Error('Error');
        }
      } catch {
        error?.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = btn.getAttribute('data-label') ?? 'Subscribe';
      }
    });
  }

  document.addEventListener('astro:page-load', initSubscribeForm);
  if (!document.documentElement.hasAttribute('data-astro-transition')) {
    initSubscribeForm();
  }
</script>
