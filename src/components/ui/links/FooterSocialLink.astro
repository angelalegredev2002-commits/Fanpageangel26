---
const { url } = Astro.props;
interface Props {
  url: string;
}
const linkClass =
  'inline-flex h-10 w-10 items-center justify-center gap-x-2 rounded-full text-sm font-bold text-neutral-300 outline-hidden ring-zinc-500 transition duration-300 hover:-translate-y-0.5 hover:text-white focus:outline-hidden focus-visible:ring-3 focus-visible:ring-zinc-500 dark:ring-zinc-200';
---

<a class={linkClass} href={url} target="_blank" rel="noopener noreferrer">
  <slot />
</a>
