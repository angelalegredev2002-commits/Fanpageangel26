---
import Meta from '@components/Meta.astro';
import '@styles/global.css';

import AppSidebar from '@components/admin/AppSidebar.astro';
import AdminHeader from '@components/admin/AdminHeader.astro';
import LoadingTransition from '@components/ui/LoadingTransition.astro';

interface Props {
  title?: string;
  lang?: string;
}

const { title = 'Admin Panel', lang = 'en' } = Astro.props;
---
<html lang={lang}>
  <head>
    <Meta meta={title} />
    <title>{title}</title>
    <script is:inline>
      if (
        localStorage.getItem('hs_theme') === 'dark' ||
        (!('hs_theme' in localStorage) &&
          window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="bg-neutral-50 dark:bg-neutral-950 text-neutral-900 dark:text-neutral-200 min-h-screen flex selection:bg-orange-500 selection:text-white transition-colors duration-300" style="font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif;">
    <LoadingTransition />
    <div class="flex flex-1 overflow-hidden relative">
      <AppSidebar />
      <main class="flex-1 flex flex-col relative overflow-hidden">
        <AdminHeader />
        <div class="flex-1 overflow-y-auto p-6 relative">
          <!-- Abstract Background -->
          <div class="absolute top-[-10%] right-[-5%] w-[40%] h-[40%] bg-orange-500/10 rounded-full blur-[100px] pointer-events-none"></div>
          <div class="absolute bottom-[-10%] left-[-5%] w-[40%] h-[40%] bg-orange-500/10 rounded-full blur-[100px] pointer-events-none"></div>
          
          <div class="relative z-10 max-w-7xl mx-auto">
            <slot />
          </div>
        </div>
      </main>
    </div>
    
    <script>
      // Sidebar Toggle Logic for Mobile
      const sidebar = document.getElementById('app-sidebar');
      const toggleBtns = document.querySelectorAll('.sidebar-toggle');
      
      toggleBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          if (sidebar) {
            sidebar.classList.toggle('-translate-x-full');
          }
        });
      });
    </script>
  </body>
</html>
