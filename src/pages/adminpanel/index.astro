---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import StatsGrid from '@components/admin/widgets/StatsGrid.astro';
import TrafficChart from '@components/admin/widgets/TrafficChart.astro';
import RecentActivity from '@components/admin/widgets/RecentActivity.astro';
---

<AdminLayout title="Admin Dashboard">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white mb-2">Dashboard Overview</h1>
    <p class="text-neutral-400">Welcome back! Here's what's happening with your project today.</p>
  </div>

  <!-- Stats Grid -->
  <StatsGrid />

  <!-- Main Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <TrafficChart />
    <RecentActivity />
  </div>
</AdminLayout>
