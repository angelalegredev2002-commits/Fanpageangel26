---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { getDB, saveDB } from '../../../utils/db';

let db = getDB();
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  if (!db.landing) db.landing = {};

  db.landing.heroTitle_es = formData.get('heroTitle_es') as string;
  db.landing.heroSubtitle_es = formData.get('heroSubtitle_es') as string;
  db.landing.heroPrimaryBtn_es = formData.get('heroPrimaryBtn_es') as string;
  db.landing.heroSecondaryBtn_es = formData.get(
    'heroSecondaryBtn_es'
  ) as string;

  db.landing.heroTitle_en = formData.get('heroTitle_en') as string;
  db.landing.heroSubtitle_en = formData.get('heroSubtitle_en') as string;
  db.landing.heroPrimaryBtn_en = formData.get('heroPrimaryBtn_en') as string;
  db.landing.heroSecondaryBtn_en = formData.get(
    'heroSecondaryBtn_en'
  ) as string;

  saveDB(db);
  success = true;
}
---

<AdminLayout title="Manage Hero Section">
  <div class="mb-8 flex items-end justify-between">
    <div>
      <h1 class="mb-2 text-3xl font-bold text-white">
        Hero Section Configuration
      </h1>
      <p class="text-neutral-400">
        Manage the main text and buttons of your landing page.
      </p>
    </div>
    {
      success && (
        <span class="rounded-xl border border-green-500/30 bg-green-500/20 px-4 py-2 text-sm font-bold text-green-400">
          ¡Cambios Guardados!
        </span>
      )
    }
  </div>

  <div
    class="rounded-2xl border border-neutral-800 bg-neutral-900/50 p-6 backdrop-blur-sm"
  >
    <form method="POST" class="space-y-6">
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
        <!-- Español -->
        <div class="space-y-4">
          <h3
            class="border-b border-neutral-800 pb-2 text-xl font-bold text-orange-400"
          >
            Español
          </h3>
          <div>
            <label class="mb-2 block text-sm font-medium text-neutral-300"
              >Título Principal (HTML permitido)</label
            >
            <input
              type="text"
              name="heroTitle_es"
              value={db.landing?.heroTitle_es || ''}
              class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:outline-none"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-neutral-300"
              >Subtítulo</label
            >
            <textarea
              name="heroSubtitle_es"
              rows="3"
              class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:outline-none"
              >{db.landing?.heroSubtitle_es || ''}</textarea
            >
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="mb-2 block text-sm font-medium text-neutral-300"
                >Botón Principal</label
              >
              <input
                type="text"
                name="heroPrimaryBtn_es"
                value={db.landing?.heroPrimaryBtn_es || ''}
                class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:outline-none"
              />
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-neutral-300"
                >Botón Secundario</label
              >
              <input
                type="text"
                name="heroSecondaryBtn_es"
                value={db.landing?.heroSecondaryBtn_es || ''}
                class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:outline-none"
              />
            </div>
          </div>
        </div>

        <!-- English -->
        <div class="space-y-4">
          <h3
            class="border-b border-neutral-800 pb-2 text-xl font-bold text-orange-400"
          >
            English
          </h3>
          <div>
            <label class="mb-2 block text-sm font-medium text-neutral-300"
              >Main Title (HTML allowed)</label
            >
            <input
              type="text"
              name="heroTitle_en"
              value={db.landing?.heroTitle_en || ''}
              class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:outline-none"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-medium text-neutral-300"
              >Subtitle</label
            >
            <textarea
              name="heroSubtitle_en"
              rows="3"
              class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:outline-none"
              >{db.landing?.heroSubtitle_en || ''}</textarea
            >
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="mb-2 block text-sm font-medium text-neutral-300"
                >Primary Button</label
              >
              <input
                type="text"
                name="heroPrimaryBtn_en"
                value={db.landing?.heroPrimaryBtn_en || ''}
                class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:outline-none"
              />
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium text-neutral-300"
                >Secondary Button</label
              >
              <input
                type="text"
                name="heroSecondaryBtn_en"
                value={db.landing?.heroSecondaryBtn_en || ''}
                class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:outline-none"
              />
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 border-t border-neutral-800 pt-4">
        <button
          type="submit"
          class="rounded-xl bg-gradient-to-r from-orange-500 to-orange-600 px-6 py-3 font-semibold text-white shadow-lg shadow-orange-500/25 transition-all hover:from-orange-400 hover:to-orange-500"
        >
          Save Settings
        </button>
      </div>
    </form>
  </div>
</AdminLayout>
