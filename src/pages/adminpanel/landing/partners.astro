---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { getDB, saveDB } from '../../../utils/db';

let db = getDB();
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  
  const rawPartners = formData.get('partnersData');
  if (rawPartners) {
    try {
      if (!db.landing) db.landing = {};
      db.landing.partners = JSON.parse(rawPartners.toString());
      saveDB(db);
      success = true;
    } catch(e) {
      console.error("Error saving partners", e);
    }
  }
}

const partners = db.landing?.partners || [];
---

<AdminLayout title="Manage Partners">
  <div class="mb-8 flex items-end justify-between">
    <div>
      <h1 class="text-3xl font-bold text-white mb-2">Clientes / Partners</h1>
      <p class="text-neutral-400">Administra los logotipos de empresas y clientes que confían en ti.</p>
    </div>
    {success && <span class="px-4 py-2 bg-green-500/20 text-green-400 rounded-xl text-sm font-bold border border-green-500/30">¡Cambios Guardados!</span>}
  </div>

  <div id="partners-app" class="space-y-8" data-partners={JSON.stringify(partners)}>
    
    <div class="bg-neutral-900/50 backdrop-blur-sm border border-neutral-800 rounded-3xl p-8">
      <div id="partners-container" class="space-y-6 mb-6"></div>
      <button id="add-partner" type="button" class="px-4 py-2 bg-neutral-800 text-neutral-300 hover:text-white rounded-xl border border-neutral-700 hover:border-neutral-500 transition-colors w-full">+ Añadir Partner</button>
    </div>

    <form method="POST" id="partners-form" class="pt-8 border-t border-neutral-800 flex justify-end">
      <input type="hidden" name="partnersData" id="partners-data-input" />
      <button type="submit" class="px-8 py-4 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-orange-500/25 text-lg">
        Guardar Configuración
      </button>
    </form>
  </div>

  <script is:inline>
    const app = document.getElementById('partners-app');
    if (app) {
      let dataPartners = JSON.parse(app.dataset.partners);

      function escapeHtml(unsafe) {
        return (unsafe||'').toString().replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
      }

      const container = document.getElementById('partners-container');
      const form = document.getElementById('partners-form');

      function renderPartners() {
        container.innerHTML = '';
        dataPartners.forEach((p, index) => {
          const div = document.createElement('div');
          div.className = 'bg-neutral-800/50 border border-neutral-700 rounded-2xl p-5 relative';
          div.innerHTML = `
            <button type="button" class="absolute top-4 right-4 text-red-400 hover:text-red-300" onclick="window.removePartner(${index})">Eliminar</button>
            <div class="space-y-4 mt-2">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="text-xs text-neutral-400">Nombre de Empresa</label>
                  <input type="text" value="${escapeHtml(p.name)}" data-field="name" data-index="${index}" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-orange-500">
                </div>
                <div>
                  <label class="text-xs text-neutral-400">Enlace (URL)</label>
                  <input type="text" value="${escapeHtml(p.href)}" data-field="href" data-index="${index}" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-orange-500">
                </div>
              </div>
              <div>
                <label class="text-xs text-neutral-400">Icono (Código SVG completo o etiqueta img)</label>
                <textarea rows="3" data-field="icon" data-index="${index}" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-orange-500 font-mono text-sm">${escapeHtml(p.icon)}</textarea>
              </div>
            </div>
          `;
          container.appendChild(div);
        });
        attachEvents();
      }

      function attachEvents() {
        container.querySelectorAll('input, textarea').forEach(el => {
          el.addEventListener('input', (e) => {
            const idx = e.target.dataset.index;
            dataPartners[idx][e.target.dataset.field] = e.target.value;
          });
        });
      }

      window.removePartner = (idx) => { dataPartners.splice(idx, 1); renderPartners(); };

      document.getElementById('add-partner').onclick = () => {
        dataPartners.push({ name: 'Nuevo Partner', href: '#', icon: '<svg viewBox="0 0 100 40"><path d="M0 0h100v40H0z" fill="#333"/></svg>' });
        renderPartners();
      };

      form.onsubmit = () => {
        document.getElementById('partners-data-input').value = JSON.stringify(dataPartners);
      };

      renderPartners();
    }
  </script>
</AdminLayout>
