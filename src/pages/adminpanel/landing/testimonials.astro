---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { getDB, saveDB } from '../../../utils/db';

let db = getDB();
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  
  const rawTestimonials = formData.get('testimonialsData');
  if (rawTestimonials) {
    try {
      if (!db.landing) db.landing = {};
      db.landing.testimonials = JSON.parse(rawTestimonials.toString());
      saveDB(db);
      success = true;
    } catch(e) {
      console.error("Error saving testimonials", e);
    }
  }

  const rawStats = formData.get('statsData');
  if (rawStats) {
    try {
      db.landing.statistics = JSON.parse(rawStats.toString());
      saveDB(db);
      success = true;
    } catch(e) {
      console.error("Error saving stats", e);
    }
  }
}

const testimonials = db.landing?.testimonials || [];
const statistics = db.landing?.statistics || [];
---

<AdminLayout title="Manage Testimonials & Stats">
  <div class="mb-8 flex items-end justify-between">
    <div>
      <h1 class="text-3xl font-bold text-white mb-2">Testimonios y Estadísticas</h1>
      <p class="text-neutral-400">Administra los testimonios de clientes y las métricas destacadas de la landing page.</p>
    </div>
    {success && <span class="px-4 py-2 bg-green-500/20 text-green-400 rounded-xl text-sm font-bold border border-green-500/30">¡Cambios Guardados!</span>}
  </div>

  <div id="testimonials-app" class="space-y-12" data-testimonials={JSON.stringify(testimonials)} data-stats={JSON.stringify(statistics)}>
    
    <!-- TESTIMONIALS SECTION -->
    <div class="bg-neutral-900/50 backdrop-blur-sm border border-neutral-800 rounded-3xl p-8">
      <h2 class="text-2xl font-bold text-orange-500 mb-6 border-b border-neutral-800 pb-4">Testimonios</h2>
      <div id="test-container" class="space-y-6 mb-6"></div>
      <button id="add-test" type="button" class="px-4 py-2 bg-neutral-800 text-neutral-300 hover:text-white rounded-xl border border-neutral-700 hover:border-neutral-500 transition-colors w-full">+ Añadir Testimonio</button>
    </div>

    <!-- STATISTICS SECTION -->
    <div class="bg-neutral-900/50 backdrop-blur-sm border border-neutral-800 rounded-3xl p-8">
      <h2 class="text-2xl font-bold text-orange-500 mb-6 border-b border-neutral-800 pb-4">Estadísticas (Métricas)</h2>
      <div id="stats-container" class="space-y-4 mb-6"></div>
      <button id="add-stat" type="button" class="px-4 py-2 bg-neutral-800 text-neutral-300 hover:text-white rounded-xl border border-neutral-700 hover:border-neutral-500 transition-colors w-full">+ Añadir Métrica</button>
    </div>

    <!-- FORM -->
    <form method="POST" id="test-form" class="pt-8 border-t border-neutral-800 flex justify-end">
      <input type="hidden" name="testimonialsData" id="testimonials-data-input" />
      <input type="hidden" name="statsData" id="stats-data-input" />
      <button type="submit" class="px-8 py-4 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-bold rounded-xl transition-all shadow-lg shadow-orange-500/25 text-lg">
        Guardar Configuración
      </button>
    </form>
  </div>

  <script>
    const app = document.getElementById('testimonials-app');
    if (app) {
      let dataTestimonials = JSON.parse(app.dataset.testimonials);
      let dataStats = JSON.parse(app.dataset.stats);

      function escapeHtml(unsafe) {
        return (unsafe||'').toString().replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
      }

      const testContainer = document.getElementById('test-container');
      const statsContainer = document.getElementById('stats-container');
      const form = document.getElementById('test-form');

      function renderTestimonials() {
        testContainer.innerHTML = '';
        dataTestimonials.forEach((t, index) => {
          const div = document.createElement('div');
          div.className = 'bg-neutral-800/50 border border-neutral-700 rounded-2xl p-5 relative';
          div.innerHTML = `
            <button type="button" class="absolute top-4 right-4 text-red-400 hover:text-red-300" onclick="window.removeTest(${index})">Eliminar</button>
            <div class="space-y-4 mt-2">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label class="text-xs text-neutral-400">Autor</label>
                  <input type="text" value="${escapeHtml(t.author)}" data-type="test" data-field="author" data-index="${index}" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-orange-500">
                </div>
                <div>
                  <label class="text-xs text-neutral-400">Rol / Empresa</label>
                  <input type="text" value="${escapeHtml(t.role)}" data-type="test" data-field="role" data-index="${index}" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-orange-500">
                </div>
              </div>
              <div>
                <label class="text-xs text-neutral-400">URL del Avatar (Imagen)</label>
                <input type="text" value="${escapeHtml(t.avatarSrc)}" data-type="test" data-field="avatarSrc" data-index="${index}" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-orange-500">
              </div>
              <div>
                <label class="text-xs text-neutral-400">Contenido (Mensaje)</label>
                <textarea rows="3" data-type="test" data-field="content" data-index="${index}" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-orange-500">${escapeHtml(t.content)}</textarea>
              </div>
            </div>
          `;
          testContainer.appendChild(div);
        });
        attachTestEvents();
      }

      function renderStats() {
        statsContainer.innerHTML = '';
        dataStats.forEach((stat, index) => {
          const div = document.createElement('div');
          div.className = 'bg-neutral-800/50 border border-neutral-700 rounded-2xl p-4 flex gap-4 items-start';
          div.innerHTML = `
            <div class="flex-1 space-y-3">
              <input type="text" placeholder="Número/Cantidad (ej: 70k+)" value="${escapeHtml(stat.count)}" data-type="stat" data-field="count" data-index="${index}" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-orange-500 font-bold">
              <input type="text" placeholder="Descripción de la métrica" value="${escapeHtml(stat.description)}" data-type="stat" data-field="description" data-index="${index}" class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-2 text-white focus:outline-none focus:border-orange-500">
            </div>
            <button type="button" class="text-red-400 hover:text-red-300 pt-2" onclick="window.removeStat(${index})">X</button>
          `;
          statsContainer.appendChild(div);
        });
        attachStatEvents();
      }

      function attachTestEvents() {
        testContainer.querySelectorAll('input, textarea').forEach(el => {
          el.addEventListener('input', (e) => {
            const idx = e.target.dataset.index;
            dataTestimonials[idx][e.target.dataset.field] = e.target.value;
          });
        });
      }

      function attachStatEvents() {
        statsContainer.querySelectorAll('input, textarea').forEach(el => {
          el.addEventListener('input', (e) => {
            const idx = e.target.dataset.index;
            dataStats[idx][e.target.dataset.field] = e.target.value;
          });
        });
      }

      window.removeTest = (idx) => { dataTestimonials.splice(idx, 1); renderTestimonials(); };
      window.removeStat = (idx) => { dataStats.splice(idx, 1); renderStats(); };

      document.getElementById('add-test').onclick = () => {
        dataTestimonials.push({ content: 'Nuevo Testimonio', author: 'Nombre', role: 'Rol', avatarSrc: '' });
        renderTestimonials();
      };
      
      document.getElementById('add-stat').onclick = () => {
        dataStats.push({ count: '0', description: 'Nueva Métrica' });
        renderStats();
      };

      form.onsubmit = () => {
        document.getElementById('testimonials-data-input').value = JSON.stringify(dataTestimonials);
        document.getElementById('stats-data-input').value = JSON.stringify(dataStats);
      };

      renderTestimonials();
      renderStats();
    }
  </script>
</AdminLayout>
