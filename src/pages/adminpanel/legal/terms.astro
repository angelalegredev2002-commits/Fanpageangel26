---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { getDB, saveDB } from '../../../utils/db';
const db = getDB();

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const content = formData.get('content')?.toString() || '';
  const content_en = formData.get('content_en')?.toString() || '';
  
  if (db.legal) {
    db.legal.terms = content;
    db.legal.terms_en = content_en;
  }
  saveDB(db);
}
---

<AdminLayout title="Terms & Conditions">
  <div class="mb-8">
    <h1 class="mb-2 text-3xl font-bold text-white">Terms & Conditions</h1>
    <p class="text-neutral-400">
      Edit your site's Terms & Conditions page content.
    </p>
  </div>

  <div
    class="flex h-[600px] flex-col rounded-2xl border border-neutral-800 bg-neutral-900/50 p-6 backdrop-blur-sm"
  >
    <form method="POST" class="flex h-full flex-col space-y-4">
      <div class="flex flex-1 flex-col gap-4 overflow-y-auto pr-2">
        <div>
          <label
            for="content"
            class="mb-2 block text-sm font-medium text-neutral-300"
            >Contenido (Español)</label
          >
          <textarea
            name="content"
            id="content"
            class="h-48 w-full resize-none rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-4 font-mono text-sm text-white transition-colors focus:border-orange-500 focus:ring-1 focus:ring-orange-500 focus:outline-none"
            >{db.legal?.terms || ''}</textarea
          >
        </div>
        <div>
          <label
            for="content_en"
            class="mb-2 block text-sm font-medium text-neutral-300"
            >Content (English)</label
          >
          <textarea
            name="content_en"
            id="content_en"
            class="h-48 w-full resize-none rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-4 font-mono text-sm text-white transition-colors focus:border-orange-500 focus:ring-1 focus:ring-orange-500 focus:outline-none"
            >{db.legal?.terms_en || ''}</textarea
          >
        </div>
      </div>

      <div>
        <button
          type="submit"
          class="rounded-xl bg-gradient-to-r from-orange-500 to-orange-600 px-6 py-3 font-semibold text-white shadow-lg shadow-orange-500/25 transition-all hover:from-orange-400 hover:to-orange-500"
        >
          Publish Changes
        </button>
      </div>
    </form>
  </div>
</AdminLayout>
