---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';

// Read all real images from the project's src/images directory
const imageFiles = import.meta.glob(
  '/src/images/**/*.{jpeg,jpg,png,gif,avif,webp,svg}',
  { eager: true }
);

const allImages = Object.entries(imageFiles).map(
  ([path, file]: [string, any], index) => {
    // Extract just the filename from the path
    const name = path.split('/').pop() || `Image ${index}`;
    // Generate a mock size based on the string length just to show something
    const mockSize = name.length * 12 + ' KB';

    return {
      id: index,
      url: file.default?.src || file.default || path, // Handle different Vite asset import formats
      name: name,
      size: mockSize,
    };
  }
);

// Pagination Logic
const itemsPerPage = 8;
const url = new URL(Astro.request.url);
const currentPage = Number(url.searchParams.get('page')) || 1;
const totalPages = Math.ceil(allImages.length / itemsPerPage) || 1;
const validPage = Math.max(1, Math.min(currentPage, totalPages));

const startIdx = (validPage - 1) * itemsPerPage;
const endIdx = startIdx + itemsPerPage;
const realImages = allImages.slice(startIdx, endIdx);
---

<AdminLayout title="Media Library">
  <div class="mb-8 flex items-end justify-between">
    <div>
      <h1 class="mb-2 text-3xl font-bold text-white">Media Library</h1>
      <p class="text-neutral-400">
        Manage your photos, images, and other visual assets.
      </p>
    </div>
    <button
      class="flex items-center gap-2 rounded-xl bg-gradient-to-r from-orange-500 to-orange-600 px-5 py-2 font-semibold text-white shadow-lg shadow-orange-500/25 transition-all hover:from-orange-400 hover:to-orange-500"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"
        ></path></svg
      >
      Upload New
    </button>
  </div>

  <!-- Drag and Drop Area -->
  <div
    class="group mb-8 w-full cursor-pointer rounded-2xl border-2 border-dashed border-neutral-700 bg-neutral-900/50 p-12 text-center transition-colors hover:border-orange-500"
  >
    <div
      class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-neutral-800 transition-transform group-hover:scale-110"
    >
      <svg
        class="h-8 w-8 text-neutral-400 transition-colors group-hover:text-orange-500"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 4v16m8-8H4"></path></svg
      >
    </div>
    <h3 class="mb-1 text-lg font-medium text-white">
      Drag and drop images here
    </h3>
    <p class="text-sm text-neutral-500">
      or click to browse from your computer (JPG, PNG, WEBP)
    </p>
  </div>

  <!-- Gallery Grid -->
  <div class="mb-8 grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-4">
    {
      realImages.map(img => (
        <div class="group overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900/50 transition-colors hover:border-orange-500/50">
          <div class="relative h-40 w-full overflow-hidden bg-neutral-800">
            <img
              src={img.url}
              alt={img.name}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 flex items-center justify-center gap-3 bg-black/50 opacity-0 backdrop-blur-sm transition-opacity group-hover:opacity-100">
              <button
                class="rounded-lg bg-neutral-800 p-2 text-white transition-colors hover:bg-orange-500"
                title="View"
              >
                <svg
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                    />
                  </>
                </svg>
              </button>
              <button
                class="rounded-lg bg-neutral-800 p-2 text-white transition-colors hover:bg-red-500"
                title="Delete"
              >
                <svg
                  class="h-5 w-5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                  />
                </svg>
              </button>
            </div>
          </div>
          <div class="p-4">
            <p class="truncate text-sm font-medium text-white" title={img.name}>
              {img.name}
            </p>
            <p class="mt-1 text-xs text-neutral-500">{img.size}</p>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Pagination Controls -->
  {
    totalPages > 1 && (
      <div class="flex items-center justify-between border-t border-neutral-800 pt-6">
        <div class="text-sm text-neutral-400">
          Mostrando página <span class="font-bold text-white">{validPage}</span>{' '}
          de <span class="font-bold text-white">{totalPages}</span>
        </div>
        <div class="flex items-center gap-2">
          <a
            href={validPage > 1 ? `?page=${validPage - 1}` : '#'}
            class={`rounded-xl px-4 py-2 text-sm font-medium transition-colors ${validPage > 1 ? 'bg-neutral-800 text-white hover:bg-neutral-700' : 'pointer-events-none cursor-not-allowed bg-neutral-900 text-neutral-600'}`}
          >
            Anterior
          </a>
          <a
            href={validPage < totalPages ? `?page=${validPage + 1}` : '#'}
            class={`rounded-xl px-4 py-2 text-sm font-medium transition-colors ${validPage < totalPages ? 'bg-neutral-800 text-white hover:bg-neutral-700' : 'pointer-events-none cursor-not-allowed bg-neutral-900 text-neutral-600'}`}
          >
            Siguiente
          </a>
        </div>
      </div>
    )
  }
</AdminLayout>
