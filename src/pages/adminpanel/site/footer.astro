---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { getDB, saveDB } from '../../../utils/db';

let db = getDB();
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  if (!db.site) db.site = {};
  db.site.footerText_es = formData.get('footerText_es') as string;
  db.site.footerText_en = formData.get('footerText_en') as string;
  saveDB(db);
  success = true;
}
---

<AdminLayout title="Manage Footer">
  <div class="mb-8 flex items-end justify-between">
    <div>
      <h1 class="mb-2 text-3xl font-bold text-white">Footer Configuration</h1>
      <p class="text-neutral-400">
        Manage your site's footer content and copyright text.
      </p>
    </div>
    {
      success && (
        <span class="rounded-xl border border-green-500/30 bg-green-500/20 px-4 py-2 text-sm font-bold text-green-400">
          ¡Cambios Guardados!
        </span>
      )
    }
  </div>

  <div
    class="rounded-2xl border border-neutral-800 bg-neutral-900/50 p-6 backdrop-blur-sm"
  >
    <form method="POST" class="space-y-6">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <div>
          <label
            for="footerText_es"
            class="mb-2 block text-sm font-medium text-neutral-300"
            >Copyright Text (Español)</label
          >
          <input
            type="text"
            id="footerText_es"
            name="footerText_es"
            value={db.site?.footerText_es || ''}
            class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:ring-1 focus:ring-orange-500 focus:outline-none"
          />
        </div>
        <div>
          <label
            for="footerText_en"
            class="mb-2 block text-sm font-medium text-neutral-300"
            >Copyright Text (English)</label
          >
          <input
            type="text"
            id="footerText_en"
            name="footerText_en"
            value={db.site?.footerText_en || ''}
            class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:ring-1 focus:ring-orange-500 focus:outline-none"
          />
        </div>
      </div>

      <div>
        <label class="mb-2 block text-sm font-medium text-neutral-300"
          >Social Media Links (Comming Soon)</label
        >
        <p class="mb-4 text-xs text-neutral-500">
          La edición de enlaces sociales se implementará próximamente.
        </p>
        <div class="pointer-events-none space-y-3 opacity-50">
          <div class="flex gap-3">
            <span
              class="inline-flex items-center rounded-xl border border-neutral-700 bg-neutral-800 px-4 text-sm text-neutral-400"
              >Twitter</span
            >
            <input
              type="url"
              value="https://twitter.com/dedicatory"
              class="flex-1 rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-2 text-white transition-colors focus:border-orange-500 focus:outline-none"
            />
          </div>
        </div>
      </div>

      <button
        type="submit"
        class="rounded-xl bg-gradient-to-r from-orange-500 to-orange-600 px-6 py-3 font-semibold text-white shadow-lg shadow-orange-500/25 transition-all hover:from-orange-400 hover:to-orange-500"
      >
        Save Changes
      </button>
    </form>
  </div>
</AdminLayout>
