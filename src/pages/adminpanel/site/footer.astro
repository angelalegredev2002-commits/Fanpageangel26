---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { getDB, saveDB } from '../../../utils/db';

let db = getDB();
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  if (!db.site) db.site = {};
  db.site.footerText_es = formData.get('footerText_es') as string;
  db.site.footerText_en = formData.get('footerText_en') as string;
  saveDB(db);
  success = true;
}
---

<AdminLayout title="Manage Footer">
  <div class="mb-8 flex items-end justify-between">
    <div>
      <h1 class="text-3xl font-bold text-white mb-2">Footer Configuration</h1>
      <p class="text-neutral-400">Manage your site's footer content and copyright text.</p>
    </div>
    {success && <span class="px-4 py-2 bg-green-500/20 text-green-400 rounded-xl text-sm font-bold border border-green-500/30">¡Cambios Guardados!</span>}
  </div>

  <div class="bg-neutral-900/50 backdrop-blur-sm border border-neutral-800 rounded-2xl p-6">
    <form method="POST" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="footerText_es" class="block text-sm font-medium text-neutral-300 mb-2">Copyright Text (Español)</label>
          <input type="text" id="footerText_es" name="footerText_es" value={db.site?.footerText_es || ''} class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-colors">
        </div>
        <div>
          <label for="footerText_en" class="block text-sm font-medium text-neutral-300 mb-2">Copyright Text (English)</label>
          <input type="text" id="footerText_en" name="footerText_en" value={db.site?.footerText_en || ''} class="w-full bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-orange-500 focus:ring-1 focus:ring-orange-500 transition-colors">
        </div>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-neutral-300 mb-2">Social Media Links (Comming Soon)</label>
        <p class="text-xs text-neutral-500 mb-4">La edición de enlaces sociales se implementará próximamente.</p>
        <div class="space-y-3 opacity-50 pointer-events-none">
          <div class="flex gap-3">
            <span class="inline-flex items-center px-4 rounded-xl border border-neutral-700 bg-neutral-800 text-neutral-400 text-sm">Twitter</span>
            <input type="url" value="https://twitter.com/dedicatory" class="flex-1 bg-neutral-800 border border-neutral-700 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-orange-500 transition-colors">
          </div>
        </div>
      </div>

      <button type="submit" class="px-6 py-3 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-400 hover:to-orange-500 text-white font-semibold rounded-xl transition-all shadow-lg shadow-orange-500/25">
        Save Changes
      </button>
    </form>
  </div>
</AdminLayout>
