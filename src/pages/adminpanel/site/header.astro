---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import { getDB, saveDB } from '../../../utils/db';

let db = getDB();
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  if (!db.site) db.site = {};
  db.site.brandText = formData.get('brandText') as string;
  db.site.stickyHeader = formData.get('stickyHeader') ? 'on' : 'off';
  saveDB(db);
  success = true;
}
---

<AdminLayout title="Manage Header">
  <div class="mb-8 flex items-end justify-between">
    <div>
      <h1 class="mb-2 text-3xl font-bold text-white">Header Configuration</h1>
      <p class="text-neutral-400">
        Manage your site's top navigation bar and logo.
      </p>
    </div>
    {
      success && (
        <span class="rounded-xl border border-green-500/30 bg-green-500/20 px-4 py-2 text-sm font-bold text-green-400">
          ¡Cambios Guardados!
        </span>
      )
    }
  </div>

  <div
    class="rounded-2xl border border-neutral-800 bg-neutral-900/50 p-6 backdrop-blur-sm"
  >
    <form method="POST" class="space-y-6">
      <div>
        <label
          for="brandText"
          class="mb-2 block text-sm font-medium text-neutral-300"
          >Brand Logo Text</label
        >
        <input
          type="text"
          id="brandText"
          name="brandText"
          value={db.site?.brandText || ''}
          class="w-full rounded-xl border border-neutral-700 bg-neutral-800 px-4 py-3 text-white transition-colors focus:border-orange-500 focus:ring-1 focus:ring-orange-500 focus:outline-none"
        />
      </div>

      <div class="flex items-center gap-3">
        <input
          type="checkbox"
          id="stickyHeader"
          name="stickyHeader"
          checked={db.site?.stickyHeader !== 'off'}
          class="h-5 w-5 rounded border-neutral-700 bg-neutral-800 text-orange-500 focus:ring-orange-500 focus:ring-offset-neutral-900"
        />
        <label for="stickyHeader" class="text-sm font-medium text-neutral-300"
          >Enable Sticky Header</label
        >
      </div>

      <button
        type="submit"
        class="rounded-xl bg-gradient-to-r from-orange-500 to-orange-600 px-6 py-3 font-semibold text-white shadow-lg shadow-orange-500/25 transition-all hover:from-orange-400 hover:to-orange-500"
      >
        Save Changes
      </button>
    </form>
  </div>
</AdminLayout>
