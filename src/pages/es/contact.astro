---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import ContactSection from '@components/sections/es/ContactSection_es.astro';
import { SITE } from '@data/constants';

const pageTitle: string = `Contáctanos | ${SITE.title}`;
const metaDescription =
  '¿Tienes preguntas o quieres discutir un proyecto? Contáctanos y permítenos elaborar la solución perfecta con nuestras herramientas y servicios.';
const ogTitle = 'Contáctanos | ERP Okanox & Sakad RMS';
---

<MainLayout
  title={pageTitle}
  lang="es"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://okanox.com/es/contact',
    url: 'https://okanox.com/es/contact',
    name: 'Contáctanos | ERP Okanox & Sakad RMS',
    description:
      '¿Tienes preguntas o quieres discutir un proyecto? Contáctanos y permítenos elaborar la solución perfecta con nuestras herramientas y servicios.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://okanox.com/es/',
      name: 'ERP Okanox & Sakad RMS',
      description:
        'ERP Okanox y Sakad RMS ofrecen soluciones integrales de gestión empresarial con 22 módulos especializados para potenciar tu negocio.',
    },
    inLanguage: 'es',
  }}
>
  <ContactSection />
</MainLayout>
