---
// Import necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';

// Import necessary images
import service1 from '@images/service1.png';
import service2 from '@images/service2.png';
import service3 from '@images/service3.png';
import service4 from '@images/service4.png';
import service5 from '@images/service5.png';
import service6 from '@images/service6.png';
import service7 from '@images/service7.png';
import service8 from '@images/service8.png';
import service9 from '@images/service9.png';
import service10 from '@images/service10.png';
import service12 from '@images/service12.png';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Hacking Ético y Antihackeo",
    subTitle:
      "Realizamos pruebas de penetración y auditorías de seguridad profundas para identificar vulnerabilidades antes que los atacantes. Implementamos estrategias antihackeo para proteger tus sistemas más críticos.",
    single: false,
    imgOne: service5,
    imgOneAlt: 'Hacking ético y auditorías de seguridad.',
    imgTwo: service6,
    imgTwoAlt: 'Detección y prevención de hackeos.',
  },
  {
    isRightSection: false,
    title: 'Equipo de Programación Especializado',
    subTitle:
      'Nuestro equipo de desarrolladores expertos crea soluciones de software escalables y eficientes. Desde sistemas ERP personalizados hasta plataformas web de alto rendimiento, transformamos tus necesidades en herramientas tecnológicas potentes.',
    img: service3,
    imgAlt: 'Equipo de programadores trabajando en soluciones de software.',
    btnExists: true,
    btnTitle: 'Saber más',
    btnURL: '#',
  },
  {
    isRightSection: true,
    title: "Ciberseguridad Avanzada",
    subTitle:
      "Protegemos tu infraestructura digital con soluciones de seguridad de última generación. Blindamos tus activos contra amenazas sofisticadas y garantizamos la integridad de tus datos mediante protocolos de seguridad avanzados.",
    single: false,
    imgOne: service7,
    imgOneAlt: 'Protección de ciberseguridad avanzada.',
    imgTwo: service8,
    imgTwoAlt: 'Certificados SSL y protocolos de seguridad.',
  },
  {
    isRightSection: false,
    title: 'Redes, Comunicación e Instalación',
    subTitle:
      "Diseñamos e implementamos infraestructuras de red robustas que garantizan una conectividad fluida y segura. Nos encargamos de todo el proceso de instalación y configuración de redes para optimizar la comunicación de tu empresa.",
    img: service1,
    imgAlt: 'Instalación de infraestructuras de red profesional.',
  },
  {
    isRightSection: true,
    title: 'Instalación de Software en Servidores Físicos',
    subTitle:
      "Somos expertos en el despliegue y optimización de sistemas en servidores físicos. Garantizamos que tu software funcione con la máxima eficiencia sobre tu hardware, asegurando estabilidad y alto rendimiento constante.",
    single: false,
    imgOne: service2,
    imgOneAlt: 'Mantenimiento de hardware y circuitos de servidor.',
    imgTwo: service4,
    imgTwoAlt: 'Configuración técnica de software en servidores.',
  },
  {
    isRightSection: false,
    title: 'QA & Testing de Software',
    subTitle:
      'Aseguramos la calidad y estabilidad de tus aplicaciones mediante procesos rigurosos de testing funcional, de rendimiento y automatización de pruebas. Entregamos software robusto y listo para producción.',
    img: service9,
    imgAlt: 'Procesos de control de calidad y testing de software.',
  },
  {
    isRightSection: true,
    title: 'Dominio de Lenguajes de Programación',
    subTitle:
      'Contamos con expertos en una amplia gama de lenguajes modernos (JavaScript, Python, Go, Rust, Java y más). Desarrollamos con las mejores prácticas para asegurar código limpio, mantenible y de alto rendimiento.',
    single: true,
    imgOne: service10,
    imgOneAlt: 'Experiencia en múltiples lenguajes de programación modernos.',
  },
  {
    isRightSection: false,
    title: 'Navegación por IA y Control Remoto',
    subTitle:
      'Implementamos navegación inteligente guiada por IA e interacciones multipantalla. Desarrollamos sistemas donde el teléfono móvil actúa como un controlador remoto para experiencias inmersivas únicas.',
    img: service12,
    imgAlt: 'Ecosistema digital con navegación IA y control móvil.',
    btnExists: true,
    btnTitle: 'Contáctanos',
    btnURL: '/es/contact',
  },
];
---

<MainLayout
  title="Servicios | Okanox ERP"
  lang="es"
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://okanox.com/es/services',
    url: 'https://okanox.com/es/services',
    name: "Servicios Tecnológicos Especializados | Okanox ERP",
    description:
      "Combinamos experiencia y visión para ofrecer soluciones tecnológicas integrales: desde ciberseguridad y hacking ético hasta desarrollo de software y gestión de redes.",
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://okanox.com/es',
      name: 'Okanox ERP',
      description:
        'Okanox ERP ofrece soluciones de software de primer nivel y servicios tecnológicos expertos para impulsar tu negocio.',
    },
    inLanguage: 'es',
  }}
>
  <MainSection
    title="Uniendo la Tecnología con tu Visión"
    subTitle="En Okanox ERP, nos enorgullecemos de ofrecer soluciones integrales y un servicio excepcional en la industria tecnológica. Nuestro equipo especializado está dedicado a impulsar tus proyectos con seguridad, eficiencia y vanguardia."
    btnExists={true}
    btnTitle="Agenda una Consultoría"
    btnURL={getRelativeLocaleUrl('es', 'contact')}
  />

  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }

  <FeaturesStats
    title="Nuestros Resultados en Cifras"
    subTitle="Nuestro compromiso con la seguridad y la innovación se refleja en cada proyecto. Nos dedicamos a proporcionar servicios tecnológicos de primer nivel que garantizan el crecimiento sostenido de tu empresa."
    mainStatTitle="98%"
    mainStatSubTitle="de nuestros clientes califican su experiencia como excepcional"
    stats={[
      {
        stat: '100%',
        description: 'de efectividad en seguridad',
      },
      {
        stat: '200+',
        description: 'proyectos de software desplegados',
      },
      {
        stat: '24/7',
        description: 'monitoreo y soporte técnico',
      },
    ]}
  />
</MainLayout>
