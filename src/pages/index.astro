---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import ClientsSection from '@components/sections/landing/ClientsSection.astro';
import LandoStorySection from '@components/sections/landing/LandoStorySection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro';
import SecuritySection from '@components/sections/features/SecuritySection.astro';
import IntegrationsSection from '@components/sections/landing/IntegrationsSection.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import PricingSection from '@components/sections/pricing/PricingSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import AnnouncementBanner from '@components/ui/banners/AnnouncementBanner.astro';
import heroImageRaw from '@images/hero-image.svg?raw';
import featureImage from '@images/features-image.png';
import construction from '@images/construction-image.avif';
import tools from '@images/automated-tools.jpg';
import dashboard from '@images/dashboard-image.avif';
import { Image } from 'astro:assets';
import { getDB } from '../utils/db';

const db = getDB();

const faqs = db.landing?.faqs_es || [];
const features = db.landing?.features_es || [];
const pricing = db.landing?.pricing_es || { plans: [] };
const partnersData = db.landing?.partners || [];
const tabsData = db.landing?.featureTabs || [];
const testimonialsData = db.landing?.testimonials || [];
const statisticsData = db.landing?.statistics || [];
const avatarSrcs = db.landing?.heroAvatars || [];
---

<MainLayout>
  <AnnouncementBanner
    btnId="dismiss-button"
    btnTitle={db.landing?.announcementBtn_es || ''}
    url={db.landing?.announcementUrl || ''}
  />

  <div class="reveal-on-scroll">
    <HeroSection
      title={db.landing?.heroTitle_es || ''}
      subTitle={db.landing?.heroSubtitle_es || ''}
      primaryBtn={db.landing?.heroPrimaryBtn_es || ''}
      primaryBtnURL="/products"
      secondaryBtn={db.landing?.heroSecondaryBtn_es || ''}
      secondaryBtnURL="/contact"
      withReview={true}
      avatars={avatarSrcs}
      rating=`<span class="font-bold">4.8</span> / 5`
      starCount={4}
      reviews=`From Over <span class="font-bold">12.8k</span> Reviews`
      svgRaw={heroImageRaw}
    />
  </div>

  <div class="reveal-on-scroll">
    <ClientsSection
      title={db.landing?.clientsTitle_es || ''}
      subTitle={db.landing?.clientsSubtitle_es || ''}
      partners={partnersData}
    />
  </div>

  <LandoStorySection locale="es" />

  <FeaturesGeneral
    title={db.landing?.featuresTitle_es || ''}
    subTitle={db.landing?.featuresSubtitle_es || ''}
    src={featureImage}
    alt="Angel Alegre solutions in floating boxes"
    features={features}
  />

  <div class="reveal-on-scroll">
    <FeaturesNavs
      title=`Personaliza las ofertas de <span class="text-orange-500 dark:text-orange-400">Angel Alegre</span> para adaptarlas perfectamente a tus necesidades de software.`
      tabs={[
        {
          heading: 'Herramientas de Vanguardia',
          content:
            'Potencia tu negocio con las herramientas de vanguardia de Angel Alegre. Experimenta una mayor eficiencia en la gestión empresarial con nuestras sofisticadas soluciones automatizadas.',
          svg: 'tools',
          src: tools,
          alt: 'Representación de herramientas automatizadas',
          first: true,
        },
        {
          heading: 'Paneles Intuitivos',
          content:
            'Navega con facilidad utilizando los paneles intuitivos de Angel Alegre. Configura y supervisa tus operaciones sin problemas.',
          svg: 'dashboard',
          src: dashboard,
          alt: 'Paneles Intuitivos',
          second: true,
        },
        {
          heading: 'Características Robustas',
          content:
            'Minimiza la complejidad, maximiza la productividad. Las robustas características de Angel Alegre están diseñadas para optimizar tus procesos comerciales.',
          svg: 'house',
          src: construction,
          alt: 'Características Robustas',
        },
        {
          heading: 'Respaldo de la Industria',
          content:
            'Implementaciones de software exitosas en diversos sectores comerciales. Colaboramos con marcas líderes para ofrecer un rendimiento de nivel empresarial.',
          svg: 'verified',
          isLogos: true,
          logos: [
            { name: 'Schott Ceran', src: '/images/clients/schott-ceran.png' },
            { name: 'Derwent', src: '/images/clients/derwent.png' },
            { name: 'Elf', src: '/images/clients/elf.png' },
            { name: 'Joe Fresh Outline', src: '/images/clients/joe-fresh-outline.png' },
            { name: 'Joe Fresh', src: '/images/clients/joe-fresh.png' },
            { name: 'Acqua Panna', src: '/images/clients/acqua-panna.png' },
          ],
          alt: 'Logos de respaldo de la industria',
        },
      ]}
    />
  </div>

  <IntegrationsSection />

  <div class="reveal-on-scroll">
    <SecuritySection />
  </div>

  <div class="reveal-on-scroll">
    <TestimonialsSection
      title={db.landing?.testimonialsTitle_es || ''}
      subTitle={db.landing?.testimonialsSubtitle_es || ''}
      testimonials={testimonialsData}
      statistics={statisticsData}
    />
  </div>

  <div class="reveal-on-scroll">
    <PricingSection
      pricing={{
        ...pricing,
        title: db.landing?.pricingTitle_es || pricing.title,
        subTitle: db.landing?.pricingSubtitle_es || pricing.subTitle,
        thirdOption: db.landing?.pricingThirdOption_es || pricing.thirdOption,
        btnText: db.landing?.pricingBtnText_es || pricing.btnText,
      }}
    />
  </div>

  <div class="reveal-on-scroll">
    <FAQ title={db.landing?.faqTitle_es || ''} faqs={faqs} />
  </div>

  <div class="reveal-on-scroll">
    <HeroSectionAlt
      title="Lidera con Okanox"
      subTitle="Gestión empresarial con precisión y potencia tecnológica."
      url="https://github.com/angelalegredev2002-commits"
    />
  </div>
</MainLayout>
