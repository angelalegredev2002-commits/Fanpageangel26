---
export const prerender = false;
import MainLayout from '@layouts/MainLayout.astro';
import { getDB } from '../utils/db';

const db = getDB();
const content = db.legal?.privacyPolicy || 'Contenido no configurado.';
---

<MainLayout title="Política de Privacidad">
  <div class="mx-auto mt-16 max-w-3xl px-4 py-24 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <h1
        class="mb-4 text-4xl font-bold text-neutral-800 md:text-5xl dark:text-neutral-200"
      >
        Política de Privacidad
      </h1>
      <p class="text-lg text-neutral-600 dark:text-neutral-400">
        Última actualización: 2026
      </p>
    </div>

    <div
      class="space-y-8 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
      set:html={content}
    />
  </div>
</MainLayout>
