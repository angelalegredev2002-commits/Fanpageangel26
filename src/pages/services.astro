---
// Import necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';
import { SITE } from '@data/constants';

// Import necessary images
import service1 from '@images/service1.png';
import service2 from '@images/service2.png';
import service3 from '@images/service3.png';
import service4 from '@images/service4.png';
import service5 from '@images/service5.png';
import service6 from '@images/service6.png';
import service7 from '@images/service7.png';
import service8 from '@images/service8.png';
import service9 from '@images/service9.png';
import service10 from '@images/service10.png';
import service12 from '@images/service12.png';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: "Ethical Hacking & Anti-hacking",
    subTitle:
      "We perform deep penetration testing and security audits to identify vulnerabilities before attackers do. We implement anti-hacking strategies to protect your most critical systems.",
    single: false,
    imgOne: service5,
    imgOneAlt: 'Ethical hacking and security audits.',
    imgTwo: service6,
    imgTwoAlt: 'Detection and prevention of hacks.',
  },
  {
    isRightSection: false,
    title: 'Specialized Development Team',
    subTitle:
      'Our team of expert developers creates scalable and efficient software solutions. From custom ERP systems to high-performance web platforms, we transform your needs into powerful technological tools.',
    img: service3,
    imgAlt: 'Development team working on software solutions.',
    btnExists: true,
    btnTitle: 'Learn More',
    btnURL: '#',
  },
  {
    isRightSection: true,
    title: "Advanced Cybersecurity",
    subTitle:
      "We protect your digital infrastructure with next-generation security solutions. We shield your assets against sophisticated threats and guarantee data integrity through advanced security protocols.",
    single: false,
    imgOne: service7,
    imgOneAlt: 'Advanced cybersecurity protection.',
    imgTwo: service8,
    imgTwoAlt: 'SSL certificates and security protocols.',
  },
  {
    isRightSection: false,
    title: 'Networking, Communication & Installation',
    subTitle:
      "We design and implement robust network infrastructures that guarantee seamless and secure connectivity. We handle the entire process of network installation and configuration to optimize your company's communication.",
    img: service1,
    imgAlt: 'Professional network infrastructure installation.',
  },
  {
    isRightSection: true,
    title: 'Software Installation on Physical Servers',
    subTitle:
      "We are experts in the deployment and optimization of systems on physical servers. We ensure that your software runs with maximum efficiency on your hardware, ensuring stability and constant high performance.",
    single: false,
    imgOne: service2,
    imgOneAlt: 'Hardware and server circuit maintenance.',
    imgTwo: service4,
    imgTwoAlt: 'Technical software configuration on servers.',
  },
  {
    isRightSection: false,
    title: 'QA & Software Testing',
    subTitle:
      'We ensure the quality and stability of your applications through rigorous functional, performance, and test automation processes. We deliver robust software ready for production.',
    img: service9,
    imgAlt: 'Quality control and software testing processes.',
  },
  {
    isRightSection: true,
    title: 'Programming Language Expertise',
    subTitle:
      'We have experts in a wide range of modern languages (JavaScript, Python, Go, Rust, Java, and more). We develop with best practices to ensure clean, maintainable, and high-performance code.',
    single: true,
    imgOne: service10,
    imgOneAlt: 'Experience in multiple modern programming languages.',
  },
  {
    isRightSection: false,
    title: 'AI Navigation & Remote Control',
    subTitle:
      'We implement intelligent AI-guided navigation and multi-screen interactions. We develop systems where the mobile phone acts as a remote controller for unique immersive experiences.',
    img: service12,
    imgAlt: 'Digital ecosystem with AI navigation and mobile control.',
    btnExists: true,
    btnTitle: 'Contact Us',
    btnURL: '/contact',
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  lang="en"
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://okanox.com/services',
    url: 'https://okanox.com/services',
    name: 'Specialized Tech Services | Okanox ERP',
    description:
      'Uniting expertise with your vision, Okanox ERP provides exceptional tech services, from cybersecurity and ethical hacking to software development and network management.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://okanox.com',
      name: 'Okanox ERP',
      description:
        'Okanox ERP offers top-tier software solutions and expert tech services to drive your business forward.',
    },
    inLanguage: 'en-US',
  }}
>
  <MainSection
    title="Uniting Technology with Your Vision"
    subTitle="At Okanox ERP, we take pride in providing comprehensive solutions and exceptional service in the technology industry. Our specialized team is dedicated to driving your projects with security, efficiency, and innovation."
    btnExists={true}
    btnTitle="Schedule a Consultation"
    btnURL="/contact"
  />

  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }

  <FeaturesStats
    title="Our Results by the Numbers"
    subTitle="Our commitment to security and innovation is evident in every project. We are dedicated to delivering industry-leading tech services that ensure your business's sustained growth."
    mainStatTitle="98%"
    mainStatSubTitle="of our clients rate their experience as exceptional"
    stats={[
      {
        stat: '100%',
        description: 'security effectiveness',
      },
      {
        stat: '200+',
        description: 'software projects deployed',
      },
      {
        stat: '24/7',
        description: 'monitoring and tech support',
      },
    ]}
  />
</MainLayout>
